/* ═════════════════════════════════════════════════════════
   TIMER
   ═════════════════════════════════════════════════════════ */
let timerInterval = null;
let timerSeconds = 600; // 10 min default
let timerTotal = 600;
let timerRunning = false;

function setTimerPreset(min){
  document.querySelectorAll('.timer-preset').forEach(e=>e.classList.remove('sel'));
  event.target.classList.add('sel');
  if(timerRunning) timerStartStop(); // para se rodando
  timerTotal = min * 60;
  timerSeconds = timerTotal;
  document.getElementById('timerCustomMin').value = min;
  updateTimerDisplay();
  document.getElementById('timerStatus').textContent = 'Pronto para iniciar';
}

function setTimerCustom(){
  const min = parseInt(document.getElementById('timerCustomMin').value)||1;
  if(timerRunning) timerStartStop();
  timerTotal = min * 60;
  timerSeconds = timerTotal;
  document.querySelectorAll('.timer-preset').forEach(e=>e.classList.remove('sel'));
  updateTimerDisplay();
}

function timerStartStop(){
  if(timerRunning){
    clearInterval(timerInterval);
    timerRunning = false;
    document.getElementById('timerStartBtn').textContent = '▶ Retomar';
    document.getElementById('timerStatus').textContent = 'Pausado';
    document.getElementById('timerFab').classList.remove('running');
  } else {
    if(timerSeconds <= 0){ timerReset(); }
    timerRunning = true;
    document.getElementById('timerStartBtn').textContent = '⏸ Pausar';
    document.getElementById('timerFab').classList.add('running');
    timerInterval = setInterval(()=>{
      timerSeconds--;
      updateTimerDisplay();
      if(timerSeconds <= 0){
        clearInterval(timerInterval);
        timerRunning = false;
        document.getElementById('timerFab').classList.remove('running');
        timerFinished();
      }
    }, 1000);
  }
}

function timerReset(){
  clearInterval(timerInterval);
  timerRunning = false;
  timerSeconds = timerTotal;
  document.getElementById('timerStartBtn').textContent = '▶ Iniciar';
  document.getElementById('timerStatus').textContent = 'Pronto para iniciar';
  document.getElementById('timerFab').classList.remove('running');
  updateTimerDisplay();
}

function updateTimerDisplay(){
  const m = Math.floor(timerSeconds/60).toString().padStart(2,'0');
  const s = (timerSeconds%60).toString().padStart(2,'0');
  const txt = `${m}:${s}`;
  const d = document.getElementById('timerDisplay');
  const f = document.getElementById('timerFabDisplay');
  if(d){ d.textContent = txt; d.classList.toggle('ending', timerSeconds<=30&&timerSeconds>0); }
  if(f){ f.innerHTML = timerSeconds>0&&timerRunning?`<div style="font-size:11px;font-weight:900;font-family:monospace">${txt}</div>`:'⏱️'; }
  document.getElementById('timerStatus').textContent = timerRunning?'Rodando...':'Pronto para iniciar';
}

function timerFinished(){
  const alarme = document.getElementById('timerAlarm')?.checked;
  document.getElementById('timerDisplay').textContent = '00:00';
  document.getElementById('timerStatus').textContent = '✅ Tempo esgotado!';
  document.getElementById('timerFabDisplay').innerHTML = '⏱️';
  document.getElementById('timerStartBtn').textContent = '▶ Iniciar';
  if(alarme){
    // Vibração
    if(navigator.vibrate) navigator.vibrate([500,200,500,200,500]);
    // Som via AudioContext
    try{
      const ctx = new (window.AudioContext||window.webkitAudioContext)();
      [0,0.4,0.8].forEach(t=>{
        const o=ctx.createOscillator();const g=ctx.createGain();
        o.connect(g);g.connect(ctx.destination);
        o.frequency.value=880;g.gain.setValueAtTime(0.4,ctx.currentTime+t);
        g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+t+0.3);
        o.start(ctx.currentTime+t);o.stop(ctx.currentTime+t+0.3);
      });
    }catch(e){}
    // Notificação
    if(Notification.permission==='granted'){
      new Notification('ConfirmaAí ⏱️', {body:'Tempo esgotado! Fim do tempo de jogo.', icon:'https://i.ibb.co/fYXRYLq4/logoconfai.png'});
    }
  }
  showToast('⏱️ Tempo esgotado!','ok');
}

