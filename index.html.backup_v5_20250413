async function togglePlayerPerm(userId, perm, value){
  const u=state.users.find(u=>u.id===userId);
  if(!u) return;
  u[perm]=value;
  const fieldMap={canCreateMatch:'pode_criar_partida',canCreateGroup:'pode_criar_grupo'};
  if(u.brId&&cfg.workerUrl&&fieldMap[perm]){
    try{ await wUpdate('usuarios',u.brId,{[fieldMap[perm]]:value}); }
    catch(e){ console.warn('togglePlayerPerm Baserow err:',e); }
  }
  saveLocal();
  const labels={canCreateMatch:'criar partidas',canCreateGroup:'criar grupos'};
  showToast(`${u.nome}: ${value?'pode':'não pode'} ${labels[perm]||perm} ${value?'✅':''}`, value?'ok':'inf');
  // Se afeta o usuário logado, atualiza estado da sessão e FAB imediatamente
  if(String(session?.id)===String(userId)){
    session[perm]=value;
    if(perm==='canCreateMatch'){
      document.getElementById('fabBtn').style.display=(isAdmin()||value)?'flex':'none';
    }
  }
  // Re-renderiza a tela de Config para refletir o novo estado
  if(document.getElementById('pageSetup')?.classList.contains('active')){
    renderSetup();
  }
}

