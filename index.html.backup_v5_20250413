function openHistory(matchId){
  const m = state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const isCreator = isAdmin() || m.createdBy===session?.id;
  const entries = m.entries||[];
  const confirmed = entries.filter(e=>e.status!=='desisted');
  const desisted = entries.filter(e=>e.status==='desisted');
  const waiting = entries.filter(e=>e.type==='waiting'&&e.status!=='desisted');
  const paid = entries.filter(e=>e.paid);
  const arrecadado = paid.length * (parseCurrency(m.taxa)||0);

  let h=`<div style="text-align:center;padding:8px 0 16px">
    <div style="font-family:var(--font-title);font-size:22px;font-weight:900;margin-bottom:4px">${m.title}</div>
    <div style="font-size:12px;color:var(--muted)">${m.date?new Date(m.date+'T00:00:00').toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'}):''}</div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">
    <div class="stat-card"><div class="stat-num">${confirmed.length}</div><div class="stat-lbl">Confirmados</div></div>
    <div class="stat-card"><div class="stat-num">${waiting.length}</div><div class="stat-lbl">Reserva</div></div>
    ${isCreator?`
    <div class="stat-card"><div class="stat-num">${desisted.length}</div><div class="stat-lbl">Desistências</div></div>
    <div class="stat-card"><div class="stat-num" style="font-size:18px">R$${arrecadado.toFixed(2)}</div><div class="stat-lbl">Arrecadado</div></div>
    `:''}
  </div>`;

  if(isCreator){
    h+=`<div class="section-sep">Lista completa</div>`;
    confirmed.forEach((e,i)=>{ h+=`<div class="player-row"><div class="player-num g">${i+1}</div><div class="player-name">${e.name}</div>${e.paid?'<span style="color:var(--green);font-size:12px">⭐ pago</span>':''}</div>`; });
    if(desisted.length){
      h+=`<div class="section-sep" style="color:var(--red)">Desistências</div>`;
      desisted.forEach(e=>{ h+=`<div class="player-row desisted"><div class="player-num r">✗</div><div class="player-name deist">${e.name}</div></div>`; });
    }
  }

  // Placares salvos
  const scores = (state.history||[]).filter(h=>h.matchId===matchId&&h.type==='score');
  if(scores.length){
    h+=`<div class="section-sep">Resultados salvos</div>`;
    scores.forEach(s=>{ h+=`<div class="player-row"><div style="font-size:18px">🏆</div><div class="player-name">${s.result}</div><div style="font-size:11px;color:var(--muted)">${s.date}</div></div>`; });
  }

  // Salvar no histórico geral
  saveMatchSnapshot(m);

  document.getElementById('historyContent').innerHTML = h;
  openModal('modalHistory');
}

function saveMatchSnapshot(m){
  if(!state.history) state.history=[];
  // Evita duplicata do mesmo match
  const existing = state.history.find(h=>h.matchId===m.id&&h.type==='snapshot');
  if(existing){ existing.updatedAt=Date.now(); return; }
  const entries=m.entries||[];
  const confirmed=entries.filter(e=>e.status!=='desisted');
  const desisted=entries.filter(e=>e.status==='desisted');
  const paid=entries.filter(e=>e.paid);
  state.history.unshift({
    id: genId(),
    matchId: m.id,
    matchTitle: m.title,
    sport: m.sport,
    date: m.date,
    type: 'snapshot',
    confirmed: confirmed.length,
    reserve: entries.filter(e=>e.type==='waiting'&&e.status!=='desisted').length,
    desisted: desisted.length,
    arrecadado: paid.length*(parseCurrency(m.taxa)||0),
    taxa: m.taxa,
    createdBy: m.createdBy,
    savedBy: session?.id,
    updatedAt: Date.now()
  });
  if(state.history.length>100) state.history=state.history.slice(0,100);
  saveLocal();
}

function renderHistoryPage(){
  const c = document.getElementById('pageHistory');
  if(!c) return;
  if(!state.history||!state.history.length){
    c.innerHTML='<div class="empty"><div class="empty-ico">📋</div><div class="empty-title">Sem histórico</div><div class="empty-desc">O histórico de partidas aparecerá aqui.</div></div>';
    return;
  }
  const snapshots = state.history.filter(h=>h.type==='snapshot');
  const mySnaps = snapshots.filter(h=>{
    const m=state.matches.find(m=>m.id===h.matchId);
    return isAdmin() || h.createdBy===session?.id || (m&&(m.entries||[]).find(e=>e.userId===session?.id));
  });
  const isAdm = isAdmin();
  let h=`<div class="sec-hdr" style="padding-left:0;padding-right:0"><div class="sec-title">📋 Histórico</div>
    <div class="sec-action" style="color:var(--red)" onclick="clearAllHistory()">🗑️ Limpar tudo</div></div>`;
  if(!mySnaps.length){ h+='<div class="empty"><div class="empty-ico">📋</div><div class="empty-title">Sem histórico</div></div>'; }
  else mySnaps.forEach(s=>{
    const sport=SPORTS[s.sport]||{emoji:'🏅'};
    const dateStr=s.date?new Date(s.date+'T00:00:00').toLocaleDateString('pt-BR'):'';
    h+=`<div class="hist-card">
      <div style="display:flex;align-items:start;gap:8px">
        <div style="font-size:24px">${sport.emoji}</div>
        <div style="flex:1">
          <div class="hist-title">${s.matchTitle}</div>
          <div class="hist-meta">
            <span class="hist-chip">📅 ${dateStr}</span>
            <span class="hist-chip">👥 ${s.confirmed} jogadores</span>
            <span class="hist-chip">⏳ ${s.reserve} reserva</span>
            ${isAdm||s.createdBy===session?.id?`<span class="hist-chip">❌ ${s.desisted} desistências</span>`:''}
            ${(isAdm||s.createdBy===session?.id)&&s.arrecadado?`<span class="hist-chip" style="color:var(--green)">💰 R$${Number(s.arrecadado).toFixed(2)}</span>`:''}
          </div>
        </div>
        <button onclick="deleteHistoryItem('${s.id}')" style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer;flex-shrink:0;padding:4px">🗑️</button>
      </div>
    </div>`;
  });
  c.innerHTML=`<div style="padding:14px">${h}</div>`;
}

function deleteHistoryItem(id){
  state.history=(state.history||[]).filter(h=>h.id!==id);
  saveLocal();renderHistoryPage();showToast('Removido do histórico','err');
}
function clearAllHistory(){
  if(!confirm('Limpar todo o histórico?')) return;
  state.history=[];saveLocal();renderHistoryPage();showToast('Histórico limpo','ok');
}

