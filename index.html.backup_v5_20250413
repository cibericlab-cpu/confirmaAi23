// Sincroniza partidas e usuários do Baserow
async function syncFromBaserow(){
  if(!cfg.workerUrl||!cfg.appSecret){
    console.warn('syncFromBaserow: Worker não configurado');
    return;
  }
  try{
    // Busca partidas — Baserow usa order_by com campo sem hífen para desc
    const pData = await wList('partidas','size=200');
    if(pData&&pData.results){
      const brMatches = pData.results.map(r=>({
        id:          String(r.id),
        brId:        r.id,
        sport:       r.esporte||'futebol',
        title:       r.titulo||'Partida',
        date:        r.data?String(r.data).split('T')[0]:'',
        start:       r.horario_inicio||'',
        end:         r.horario_fim||'',
        local:       r.local||'',
        mapUrl:      r.mapa_url||'',
        maxPlayers:  Number(r.vagas_principais)||12,
        minPlayers:  Number(r.quorum_minimo)||18,
        reserveSlots:Number(r.vagas_reserva)||5,
        recurring:   r.recorrencia||'none',
        listType:    r.tipo_lista||'open',
        groupIds:    [],
        gratuito:    r.gratuito||false,
        taxa:        r.taxa?String(r.taxa):'',
        pix:         r.pix||'',
        pixNome:     r.pix_nome||'',
        obs:         r.observacao||'',
        status:      r.status||'open',
        done:        r.status==='done',
        entries:     [],
        createdBy:   String(r.criado_por||''),
        createdAt:   Date.now(),
        _fromBR:     true
      }));
      // Ordena por id desc (mais recente primeiro)
      brMatches.sort((a,b)=>b.brId-a.brId);
      // Mescla: mantém entradas locais que não são do Baserow
      const localOnly = state.matches.filter(m=>!m._fromBR&&!m.brId);
      state.matches = [...brMatches, ...localOnly];
      console.log(`syncFromBaserow: ${brMatches.length} partidas carregadas`);
    }

    // Busca usuários (apenas admin vê todos; player vê só si mesmo)
    if(isAdmin()){
      const uData = await wList('usuarios','size=200');
      if(uData&&uData.results){
        state.users = uData.results.map(r=>({
          id:             String(r.id),
          brId:           r.id,
          nome:           r.nome||'',
          login:          r.login||'',
          senha:          r.senha||'',
          level:          r.nivel||'player',
          sports:         (r.modalidades||'').split(',').map(s=>s.trim()).filter(Boolean),
          canCreateMatch: !!(r.pode_criar_partida),
          canCreateGroup: !!(r.pode_criar_grupo),
          aprovado:       r.aprovado!==false,
          avatar:         r.avatar||'',
          userId:         r.user_id||String(r.id),
          ativo:          r.ativo!==false
        }));
        console.log(`syncFromBaserow: ${state.users.length} usuários carregados`);

        // Notifica admin sobre pendentes de aprovação
        const pending = state.users.filter(u=>!u.aprovado&&u.nivel!=='admin');
        if(pending.length>0){
          addNotif(`⏳ ${pending.length} cadastro(s) aguardando aprovação`);
          const nb=document.getElementById('notifBadge');
          if(nb){nb.style.display='flex';nb.textContent=Math.min(state.notifications.length,9);}
        }
      }
    }

    saveLocal();
    render();
    showToast(`Sincronizado! ${state.matches.length} partidas carregadas ✅`,'ok');
  }catch(e){
    console.error('syncFromBaserow erro:',e);
