const TUT_TOTAL = 7; // slides 0-6
let tutCurrent = 0;

function openTutorial(){
  tutCurrent = 0;
  tutRenderSlide();
  document.getElementById('modalTutorial').classList.add('open');
}

function closeTutorial(){
  document.getElementById('modalTutorial').classList.remove('open');
  localStorage.setItem('cai_tutorial_seen','1');
}

function tutNav(dir){
  const next = tutCurrent + dir;
  if(next < 0) return;
  if(next >= TUT_TOTAL){ closeTutorial(); return; }
  tutCurrent = next;
  tutRenderSlide();
}

function tutRenderSlide(){
  // Mostra/oculta slides
  for(let i=0;i<TUT_TOTAL;i++){
    const el=document.getElementById('tslide'+i);
    if(el) el.style.display = i===tutCurrent ? '' : 'none';
  }
  // Dots
  const dots=document.getElementById('tutDots');
  if(dots){
    dots.innerHTML = Array.from({length:TUT_TOTAL},(_,i)=>
      `<div class="tut-dot ${i===tutCurrent?'active':''}" onclick="tutGoto(${i})"></div>`
    ).join('');
  }
  // Botões
  const back=document.getElementById('tutBtnBack');
  const next=document.getElementById('tutBtnNext');
  if(back) back.style.display = tutCurrent===0 ? 'none' : '';
  if(next){
    next.textContent = tutCurrent===TUT_TOTAL-1 ? '🚀 Começar!' : 'Próximo →';
  }
}

function tutGoto(idx){
  tutCurrent=idx;
  tutRenderSlide();
}

