function openNewMatch(){
  const d=new Date();d.setDate(d.getDate()+1);
  document.getElementById('mDate').value=d.toISOString().split('T')[0];
  // Preenche picker de locais
  populateLocalPicker('mLocalPicker');
  buildGroupPicker();
  openModal('modalMatch');
}

function populateLocalPicker(selectId){
  const sel=document.getElementById(selectId);
  if(!sel) return;
  const locais=state.locais||[];
  sel.innerHTML=`<option value="">— Digitar manualmente —</option>`
    + locais.map(l=>`<option value="${l.id}">${l.nome} — ${l.endereco||''}</option>`).join('');
}

function applyLocalPicker(){
  const sel=document.getElementById('mLocalPicker');
  const localId=sel.value;
  const manual=document.getElementById('mLocalManual');
  if(!localId){ manual.style.display=''; return; }
  const l=(state.locais||[]).find(l=>l.id===localId);
  if(!l){ manual.style.display=''; return; }
  manual.style.display='none';
  document.getElementById('mLocal').value=l.nome;
  document.getElementById('mMapUrl').value=l.mapa||'';
}

function buildGroupPicker(){
  // Mostra grupos do usuário logado
  const myGroups=(state.groups||[]).filter(g=>g.createdBy===session?.id||isAdmin());
  const myGroupsEl=document.getElementById('myGroupsList');
  if(myGroupsEl){
    if(myGroups.length){
      myGroupsEl.innerHTML=`<div style="font-size:11px;color:var(--muted);margin-bottom:6px;font-weight:700">SEUS GRUPOS:</div>`
        +myGroups.map(g=>`
          <div class="user-pick" data-gid="${g.id}" onclick="selectGroupForMatch(this,'${g.id}')" style="margin-bottom:5px">
            <div class="user-pick-check">✓</div>
            <div style="font-size:20px">${SPORTS[g.sport]?.emoji||'👥'}</div>
            <div style="flex:1"><div style="font-size:13px;font-weight:600">${g.nome}</div>
            <div style="font-size:11px;color:var(--muted)">${(g.members||[]).length} membros</div></div>
          </div>`).join('');
    } else {
      myGroupsEl.innerHTML='';
    }
  }
  // Mostra jogadores individuais
  const container=document.getElementById('userPickList');
  if(container){
    container.innerHTML=`<div style="font-size:11px;color:var(--muted);margin-bottom:6px;font-weight:700">OU SELECIONE JOGADORES:</div>`
      +state.users.filter(u=>u.level==='player'&&u.aprovado!==false).map(u=>`
        <div class="user-pick" data-uid="${u.id}" onclick="toggleUserPick(this)">
          <div class="user-pick-check">✓</div>
          <div style="width:28px;height:28px;border-radius:50%;background:var(--bg5);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">${u.avatar||u.nome?.charAt(0)||'?'}</div>
          <div style="flex:1"><div style="font-size:13px;font-weight:600">${u.nome}</div><div style="font-size:11px;color:var(--muted)">@${u.login}</div></div>
        </div>`).join('');
  }
}

function selectGroupForMatch(el, groupId){
  // Seleciona um grupo e marca todos os membros
  document.querySelectorAll('#myGroupsList .user-pick').forEach(e=>e.classList.remove('sel'));
  el.classList.toggle('sel');
  const g=(state.groups||[]).find(g=>g.id===groupId);
  if(!g) return;
  // Desmarca todos os jogadores e marca os do grupo
  document.querySelectorAll('#userPickList .user-pick').forEach(e=>{
    e.classList.toggle('sel', g.members.some(m=>m.id===e.dataset.uid));
  });
}

function toggleUserPick(el){el.classList.toggle('sel')}

function toggleGroupPicker(){
  const v=document.getElementById('mListType').value;
  const show=v==='group'||v==='invite'||v==='private';
  document.getElementById('groupPicker').style.display=show?'':'none';
  const lbl=document.getElementById('groupPickerLabel');
  if(lbl){
    if(v==='private') lbl.textContent='Convidados da partida privada';
    else if(v==='group'||v==='invite') lbl.textContent='Selecionar grupo ou jogadores';
  }
}
function toggleTaxFields(){document.getElementById('taxFields').style.display=document.getElementById('mChargeTax').checked?'':'none'}

async function createMatch(){
  const sport=document.querySelector('#matchSportGrid .sel')?.dataset.sport||'futebol';
  const chargeTax=document.getElementById('mChargeTax').checked;
  const listType=document.getElementById('mListType').value;
  const groupIds=listType!=='open'?[...document.querySelectorAll('#userPickList .sel')].map(e=>e.dataset.uid):[];
  const m={
    id:genId(),sport,
    title:document.getElementById('mTitle').value.trim()||(SPORTS[sport]?.label+' - '+new Date().toLocaleDateString('pt-BR')),
    date:document.getElementById('mDate').value,
    start:document.getElementById('mStart').value,
    end:document.getElementById('mEnd').value,
    local:document.getElementById('mLocal').value.trim(),
    mapUrl:document.getElementById('mMapUrl').value.trim(),
    maxPlayers:parseInt(document.getElementById('mMax').value)||12,
    minPlayers:parseInt(document.getElementById('mMin').value)||18,
    reserveSlots:parseInt(document.getElementById('mReserve').value)||5,
    recurring:document.getElementById('mRecurring').value,
    listType,groupIds,
    gratuito:!chargeTax,
    taxa:chargeTax?String(parseCurrency(document.getElementById('mTaxa').value)):'',
    pix:chargeTax?document.getElementById('mPix').value.trim():'',
    pixNome:chargeTax?document.getElementById('mPixNome').value.trim():'',
    obs:document.getElementById('mObs').value.trim(),
    status:'open',done:false,entries:[],createdBy:session?.id,createdAt:Date.now()
  };
  state.matches.unshift(m);
  if(cfg.workerUrl&&cfg.appSecret){
    const br=await wCreate('partidas',{
      titulo:m.title,esporte:m.sport,data:m.date,horario_inicio:m.start,horario_fim:m.end,
      local:m.local,mapa_url:m.mapUrl,vagas_principais:m.maxPlayers,quorum_minimo:m.minPlayers,
      vagas_reserva:m.reserveSlots,recorrencia:m.recurring,tipo_lista:m.listType,
      grupos_ids:JSON.stringify(groupIds),gratuito:m.gratuito,taxa:parseCurrency(m.taxa),
      pix:m.pix,pix_nome:m.pixNome,observacao:m.obs,status:'open'
    });
    if(br) m.brId=br.id;
  }
  saveLocal();
  closeModal('modalMatch');
  addNotif(`Partida "${m.title}" criada! 🎉`);
  showToast('Partida criada!','ok');
  navigate('home');
}

