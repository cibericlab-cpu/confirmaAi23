/* ═════════════════════════════════════════════════════════
   ENTRIES (inscriptions)
   ═════════════════════════════════════════════════════════ */
function determineEntryType(m){
  const confirmed=(m.entries||[]).filter(e=>e.type==='confirmed'&&e.status!=='desisted');
  const quorum=(m.entries||[]).filter(e=>e.type==='quorum'&&e.status!=='desisted');
  const waiting=(m.entries||[]).filter(e=>e.type==='waiting'&&e.status!=='desisted');
  if(confirmed.length<m.maxPlayers) return 'confirmed';
  if(m.minPlayers>m.maxPlayers&&quorum.length<(m.minPlayers-m.maxPlayers)) return 'quorum';
  if(waiting.length<(m.reserveSlots||5)) return 'waiting';
  return null;
}

async function joinMatch(matchId){
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  if((m.entries||[]).find(e=>e.userId===session.id&&e.status!=='desisted')){showToast('Você já está na lista','inf');return}
  const type=determineEntryType(m);
  if(!type){showToast('Lista completa!','err');return}
  const e={id:genId(),userId:session.id,name:session.nome,type,status:'active',paid:false,receiptUrl:'',time:now()};
  m.entries=[...(m.entries||[]),e];
  if(cfg.workerUrl&&cfg.appSecret&&m.brId){
    const br=await wCreate('inscricoes',{partida_id:m.brId,usuario_id:session.brId||0,nome_exibicao:e.name,tipo:type,status:'active',pago:false,horario_inscricao:new Date().toISOString()});
    if(br) e.brId=br.id;
  }
  saveLocal();navigate('home');
  const labels={confirmed:'confirmada ✅',quorum:'no quórum mínimo 🟡',waiting:'na lista de reserva ⏳'};
  addNotif(`Sua presença em "${m.title}" foi ${labels[type]}`);
  showToast(`Presença ${labels[type]}`,'ok');
}

async function addPlayerAdmin(matchId){
  const inp=document.getElementById('ai_'+matchId);
  const name=inp?.value?.trim();
  if(!name) return;
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const type=determineEntryType(m);
  if(!type){showToast('Todas as listas estão cheias!','err');return}
  const e={id:genId(),userId:null,name,type,status:'active',paid:false,receiptUrl:'',time:now()};
  m.entries=[...(m.entries||[]),e];
  if(inp) inp.value='';
  if(cfg.workerUrl&&cfg.appSecret&&m.brId){
    const br=await wCreate('inscricoes',{partida_id:m.brId,nome_exibicao:name,tipo:type,status:'active',pago:false});
    if(br) e.brId=br.id;
  }
  saveLocal();navigate('home');
  addNotif(`${name} adicionado à "${m.title}"`);
  showToast(`${name} adicionado!`,'ok');
}

async function leaveMatch(matchId){
  if(!confirm('Deseja desistir da partida?')) return;
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const e=(m.entries||[]).find(en=>en.userId===session.id&&en.status!=='desisted');
  if(!e) return;
  e.status='desisted';
  promoteAfterLeave(m,e.type);
  if(cfg.workerUrl&&cfg.appSecret&&e.brId) await wUpdate('inscricoes',e.brId,{status:'desisted'});
  saveLocal();navigate('home');
  addNotif(`Você desistiu de "${m.title}"`);
  showToast('Desistência registrada','err');
}

function removeEntry(matchId,entryId){
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const e=(m.entries||[]).find(en=>en.id===entryId);
  if(!e) return;
  e.status='desisted';
  promoteAfterLeave(m,e.type);
  saveLocal();navigate('home');showToast('Jogador removido','err');
}

function promoteAfterLeave(m,type){
  if(type==='confirmed'){
    const next=(m.entries||[]).find(e=>e.type==='quorum'&&e.status!=='desisted');
    if(next){next.type='confirmed';addNotif(`${next.name} promovido para a lista principal de "${m.title}"! 🎉`);return}
  }
  if(type==='confirmed'||type==='quorum'){
    const next=(m.entries||[]).find(e=>e.type==='waiting'&&e.status!=='desisted');
    if(next){next.type=type;addNotif(`${next.name} saiu da reserva em "${m.title}"! 🎉`)}
  }
}

function promoteEntry(matchId,entryId){
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const e=(m.entries||[]).find(en=>en.id===entryId);
  if(!e) return;
  if(e.type==='waiting') e.type='quorum';
  else if(e.type==='quorum') e.type='confirmed';
  saveLocal();navigate('home');showToast(`${e.name} promovido ⬆️`,'ok');
}

/* ═════════════════════════════════════════════════════════
   PAYMENT
   ═════════════════════════════════════════════════════════ */
function openPayment(matchId,entryId){
  const m=state.matches.find(m=>m.id===matchId);
  const e=(m?.entries||[]).find(en=>en.id===entryId);
  if(!m||!e) return;
  paymentCtx={matchId,entryId};
  const canAdmin=isAdmin();
  const canSelf=e.userId===String(session?.id);
  const canAct=canAdmin||canSelf;

  let h=`<div style="text-align:center;margin-bottom:20px">
    <div style="font-size:52px;margin-bottom:8px">${e.paid?'⭐':'💵'}</div>
    <div style="font-family:var(--font-title);font-size:22px;font-weight:800">${e.name}</div>
    <div style="color:var(--muted);font-size:13px">Partida: ${m.title}</div>
    <div style="margin-top:8px"><span class="status-badge ${e.paid?'status-open':'status-closed'}" style="font-size:13px;padding:6px 14px">${e.paid?'✅ PAGO':'⏳ PENDENTE'}</span></div>
  </div>`;

  if(m.taxa) h+=`<div class="meta-chip" style="justify-content:center;margin-bottom:12px;font-size:14px">💰 Taxa: <strong style="font-size:16px">R$ ${parseCurrency(m.taxa).toFixed(2)}</strong></div>`;

  if(m.pix) h+=`<div style="background:var(--bg4);border-radius:var(--r-sm);padding:14px;text-align:center;margin-bottom:14px;cursor:pointer;border:1px solid rgba(0,255,135,.2)" onclick="copyPix('${m.pix}','${m.pixNome||''}')" title="Toque para copiar">
    <div style="font-size:10px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.8px">Chave PIX — toque para copiar</div>
    <div style="font-size:17px;font-weight:800;color:var(--green)">${m.pix}</div>
    ${m.pixNome?`<div style="font-size:12px;color:var(--muted);margin-top:2px">${m.pixNome}</div>`:''}
    <div style="margin-top:6px;font-size:11px;color:var(--cyan)">📋 Toque para copiar</div>
  </div>`;

  // Botão principal de confirmar — disponível para admin E para o próprio jogador
  if(canAct && !e.paid){
    h+=`<button class="btn btn-primary btn-full" style="margin-bottom:10px" onclick="togglePayment('${matchId}','${entryId}')">
      ⭐ Confirmar pagamento
    </button>`;
  }
  if(canAct && e.paid){
    h+=`<button class="btn btn-ghost btn-full" style="margin-bottom:10px" onclick="togglePayment('${matchId}','${entryId}')">
      ↩️ Marcar como pendente
    </button>`;
  }

  // Comprovante — opcional, só aparece se pode agir
  if(canAct){
    if(e.receiptUrl){
      h+=`<div class="receipt-preview" style="margin-bottom:10px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">📎 Comprovante anexado</div>
        <img src="${e.receiptUrl}" class="receipt-img" alt="Comprovante" style="max-width:100%" />
      </div>`;
    }
    h+=`<div class="upload-area" onclick="document.getElementById('receiptFile_${entryId}').click()" style="font-size:13px">
      📎 ${e.receiptUrl?'Trocar comprovante (opcional)':'Anexar comprovante (opcional)'}
      <div style="font-size:11px;color:var(--muted);margin-top:4px">O comprovante não é obrigatório para confirmar</div>
      <input type="file" id="receiptFile_${entryId}" accept="image/*,application/pdf" onchange="uploadReceipt(event)" style="display:none" />
    </div>`;
  }

  document.getElementById('paymentContent').innerHTML=h;
  openModal('modalPayment');
}

function togglePayment(matchId,entryId){
  const m=state.matches.find(m=>m.id===matchId);
  const e=(m?.entries||[]).find(en=>en.id===entryId);
  if(!e) return;
  e.paid=!e.paid;
  saveLocal();
  openPayment(matchId,entryId);
  navigate('home');
  showToast(e.paid?`${e.name} marcado como PAGO ⭐`:`${e.name} marcado como pendente`,'ok');
}

async function uploadReceipt(event){
  const file=event.target.files[0];
  if(!file) return;
  const reader=new FileReader();
  reader.onload=function(ev){
    const ctx=paymentCtx;
    if(!ctx) return;
    const m=state.matches.find(m=>m.id===ctx.matchId);
    const e=(m?.entries||[]).find(en=>en.id===ctx.entryId);
    if(!e) return;
    e.receiptUrl=ev.target.result; // base64 local
    saveLocal();
    openPayment(ctx.matchId,ctx.entryId);
    navigate('home');
    showToast('Comprovante anexado! 📎','ok');
  };
  reader.readAsDataURL(file);
}

