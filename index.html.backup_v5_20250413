   ═════════════════════════════════════════════════════════ */
let deferredPrompt = null;

// Captura o evento — preventDefault() é obrigatório para controlar o timing
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  // Só mostra banner se o app já estiver aberto (usuário logado)
  // usa delay para garantir que o DOM do app esteja visível
  if (!isAppInstalled()) {
    setTimeout(() => {
      if (document.getElementById('mainApp').style.display !== 'none') {
        showInstallBanner();
      }
    }, 2000);
  }
});

window.addEventListener('appinstalled', () => {
  deferredPrompt = null;
  hideInstallBanner();
  showToast('App instalado com sucesso! 🎉', 'ok');
});

function isAppInstalled() {
  return window.matchMedia('(display-mode: standalone)').matches
    || window.navigator.standalone === true
    || document.referrer.includes('android-app://');
}

function showInstallBanner() {
  if (isAppInstalled() || !deferredPrompt) return;
  const b = document.getElementById('installBanner');
  if (!b) return;
  b.style.display = 'flex';
  // Força reflow antes da animação
  void b.offsetHeight;
  b.style.transform = 'translateY(0)';
  b.style.opacity = '1';
}

function hideInstallBanner() {
  const b = document.getElementById('installBanner');
  if (!b) return;
  b.style.transform = 'translateY(120px)';
  b.style.opacity = '0';
  setTimeout(() => { b.style.display = 'none'; }, 400);
}

async function installPWA() {
  if (deferredPrompt) {
    try {
      await deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      hideInstallBanner();
      if (outcome === 'accepted') {
        showToast('ConfirmaAí instalado! 🎉', 'ok');
      } else {
        showInstallInstructions();
      }
    } catch(e) {
      console.warn('PWA install error:', e);
      showInstallInstructions();
    }
  } else if (isAppInstalled()) {
    showToast('App já está instalado! ✅', 'ok');
  } else {
    showInstallInstructions();
  }
}

function showInstallInstructions(){
  const ua = navigator.userAgent;
  const isIOS = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;
  const isSamsung = /SamsungBrowser/.test(ua);
  const isAndroid = /Android/.test(ua);
  if(isIOS){
    showToast('iOS Safari: toque em compartilhar (□↑) → "Adicionar à Tela Inicial"', 'inf');
  } else if(isSamsung){
    showToast('Samsung: menu (⋮) → "Adicionar página a" → "Tela inicial"', 'inf');
  } else if(isAndroid){
    showToast('Android Chrome: menu (⋮) → "Adicionar à tela inicial"', 'inf');
  } else {
    showToast('Desktop: clique no ícone ➕ na barra de endereço', 'inf');
  }
}

function checkAndShowInstallBanner() {
  if (!isAppInstalled() && deferredPrompt) {
    setTimeout(showInstallBanner, 2500);
  }
}

