function openAddMember(groupId){
  const g=(state.groups||[]).find(g=>g.id===groupId);
  if(!g) return;
  const available=state.users.filter(u=>u.aprovado!==false&&!g.members.find(m=>m.id===u.id));
  if(!available.length){showToast('Todos os jogadores já estão no grupo','inf');return}
  // Simple prompt
  const nome=prompt(`Adicionar membro ao grupo "${g.nome}".\nDigite o nome/login:`);
  if(!nome) return;
  const u=state.users.find(u=>u.nome.toLowerCase().includes(nome.toLowerCase())||u.login.includes(nome.toLowerCase()));
  if(!u){showToast('Jogador não encontrado','err');return}
  if(g.members.find(m=>m.id===u.id)){showToast('Jogador já está no grupo','inf');return}
  g.members.push({id:u.id,nome:u.nome});
  saveLocal();renderGroups();
  showToast(`${u.nome} adicionado ao grupo!`,'ok');
}

function deleteGroup(id){
  if(!confirm('Excluir este grupo?')) return;
  state.groups=(state.groups||[]).filter(g=>g.id!==id);
  saveLocal();renderGroups();showToast('Grupo excluído','err');
}

function removeMemberFromGroup(groupId, memberId){
  const g=(state.groups||[]).find(g=>g.id===groupId);
  if(!g) return;
  g.members=(g.members||[]).filter(m=>m.id!==memberId);
  saveLocal();renderGroups();showToast('Membro removido','inf');
}

/* ═════════════════════════════════════════════════════════
   SOLICITAÇÃO DE ENTRADA EM GRUPO
   ═════════════════════════════════════════════════════════ */
function requestJoinGroup(groupId){
  const g=(state.groups||[]).find(g=>g.id===groupId);
  if(!g) return;
  if(!state.groupRequests) state.groupRequests=[];
  // Verifica se já solicitou
  const existing=state.groupRequests.find(r=>r.groupId===groupId&&r.userId===session?.id&&r.status==='pending');
  if(existing){showToast('Solicitação já enviada, aguarde aprovação','inf');return;}
  // Verifica se já é membro
  if(g.members&&g.members.find(m=>m.id===session?.id)){showToast('Você já é membro deste grupo','inf');return;}
  const req={id:genId(),groupId,groupNome:g.nome,userId:session?.id,userName:session?.nome,status:'pending',createdAt:Date.now()};
  state.groupRequests.push(req);
  saveLocal();
  // Notifica o criador/admin
  addNotif(`👥 ${session?.nome} solicitou entrada no grupo "${g.nome}"`);
  showToast(`Solicitação enviada para o grupo "${g.nome}"! Aguarde aprovação 📩`,'ok');
  renderGroups();
}

function approveJoinRequest(reqId){
  const req=(state.groupRequests||[]).find(r=>r.id===reqId);
  if(!req) return;
  req.status='approved';
  const g=(state.groups||[]).find(g=>g.id===req.groupId);
  if(g){
    if(!g.members) g.members=[];
    g.members.push({id:req.userId,nome:req.userName});
  }
  saveLocal();renderGroups();
  addNotif(`✅ Você foi aprovado no grupo "${req.groupNome}"!`);
  showToast(`${req.userName} aprovado no grupo!`,'ok');
}

function rejectJoinRequest(reqId){
  const req=(state.groupRequests||[]).find(r=>r.id===reqId);
  if(!req) return;
  req.status='rejected';
  saveLocal();renderGroups();
  showToast('Solicitação recusada','inf');
}

