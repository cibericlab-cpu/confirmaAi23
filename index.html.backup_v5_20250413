async function doLogin(){
  const login=document.getElementById('lLogin').value.trim().toLowerCase();
  const senha=document.getElementById('lSenha').value;
  const errEl=document.getElementById('loginErr');
  errEl.textContent='';

  if(!login||!senha){errEl.textContent='Preencha login e senha';return}

  if(!cfg.appSecret){
    errEl.innerHTML='⚠️ Código secreto não configurado.<br><small style="opacity:.7">Admin: configure em Perfil → Conexão Segura.</small>';
    return;
  }

  errEl.textContent='⏳ Verificando...';
  errEl.style.color='var(--muted)';

  try{
    // Busca usuário pelo login no Baserow via Worker
    // Baserow com user_field_names=true aceita: filter__login__equal
    const data = await wList('usuarios', `filter__login__equal=${encodeURIComponent(login)}&size=1`);

    if(!data){
      errEl.style.color='var(--red)';
      errEl.textContent='❌ Erro ao conectar ao servidor. Verifique a configuração do Worker.';
      return;
    }

    if(!data.results||data.results.length===0){
      errEl.style.color='var(--red)';
      errEl.textContent='Login não encontrado.';
      return;
    }

    const u = data.results[0];

    // Verifica conta ativa/aprovada
    if(u.ativo===false || u.aprovado===false){
      errEl.style.color='var(--amber)';
      errEl.innerHTML='⏳ Cadastro aguardando aprovação do administrador.<br><small style="opacity:.7">Você será notificado quando for aprovado.</small>';
      return;
    }

    // Verifica senha
    if(u.senha !== senha){
      errEl.style.color='var(--red)';
      errEl.textContent='Senha incorreta.';
      return;
    }

    // Login bem-sucedido
    saveRemember(login, senha);
    startSession({
      id:    String(u.id),
      brId:  u.id,
      nome:  u.nome,
      login: u.login,
      level: u.nivel || u.level || 'player',
      sports:(u.modalidades||'').split(',').map(s=>s.trim()).filter(Boolean)
    });

  } catch(e) {
    errEl.style.color='var(--red)';
    errEl.textContent='Erro inesperado. Tente novamente.';
    console.error('Login error:', e);
  }
}

