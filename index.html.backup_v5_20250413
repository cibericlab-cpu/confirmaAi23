  document.getElementById('eStart').value=m.start||'';
  document.getElementById('eEnd').value=m.end||'';
  document.getElementById('eLocal').value=m.local||'';
  document.getElementById('eMapUrl').value=m.mapUrl||'';
  document.getElementById('eMax').value=m.maxPlayers||12;
  document.getElementById('eMin').value=m.minPlayers||18;
  document.getElementById('eReserve').value=m.reserveSlots||5;
