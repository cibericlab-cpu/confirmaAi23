function openShare(matchId){
  shareMatchId=matchId;
  document.getElementById('shareText').textContent=generateShareText(matchId);
  openModal('modalShare');
}

function generateShareText(matchId){
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return '';
  const emoji=SPORTS[m.sport]?.emoji||'🏅';
  const conf=(m.entries||[]).filter(e=>e.type==='confirmed'&&e.status!=='desisted');
  const quo=(m.entries||[]).filter(e=>e.type==='quorum'&&e.status!=='desisted');
  const wait=(m.entries||[]).filter(e=>e.type==='waiting'&&e.status!=='desisted');
  const dStr=m.date?new Date(m.date+'T00:00:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'long',weekday:'long'}):'';
  const lines=[`${emoji} ${m.title} ${emoji}`];
  if(dStr) lines.push(`Data: ${dStr}`);
  if(m.start||m.end) lines.push(`Horário: das ${m.start||'?'} às ${m.end||'?'}`);
  if(m.obs) lines.push(`OBS.: ${m.obs}`);
  if(m.local){lines.push(`Local: ${m.local}`);if(m.mapUrl) lines.push(m.mapUrl)}
  if(m.taxa) lines.push(`Taxa: R$${parseCurrency(m.taxa).toFixed(2)} pessoa/jogo`);
  if(m.pix){lines.push(`PIX: ${m.pix}`);if(m.pixNome) lines.push(`(${m.pixNome})`)}
  lines.push('');lines.push('Elenco:');
  for(let i=0;i<m.maxPlayers;i++) lines.push(`${i+1}. ${conf[i]?.name||''}`);
  if(m.minPlayers>m.maxPlayers){lines.push('');lines.push('------------- QUORUM MINIMO -------------');for(let i=0;i<(m.minPlayers-m.maxPlayers);i++) lines.push(`${m.maxPlayers+i+1}. ${quo[i]?.name||''}`)}
  if(wait.length){lines.push('');lines.push('Lista de Reserva');wait.forEach((p,i)=>lines.push(`${i+1}. ${p.name}`))}
  return lines.join('\n');
}

function shareWA(){window.open(`https://wa.me/?text=${encodeURIComponent(generateShareText(shareMatchId))}`,'_blank')}
function copyShare(){
  const t=generateShareText(shareMatchId);
  navigator.clipboard?.writeText(t).catch(()=>{const ta=document.createElement('textarea');ta.value=t;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta)});
  showToast('Copiado! 📋','ok');
}

