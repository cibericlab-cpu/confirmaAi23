/* ═════════════════════════════════════════════════════════
   NAVIGATION + HISTÓRICO
   ═════════════════════════════════════════════════════════ */
let navHistory = [];

function navigate(page){
  const prev = navHistory[navHistory.length-1];
  if(prev && prev !== page) navHistory.push(page);
  else if(!prev) navHistory = [page];
  else navHistory[navHistory.length-1] = page;

  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page'+page.charAt(0).toUpperCase()+page.slice(1))?.classList.add('active');
  document.getElementById('nav-'+page)?.classList.add('active');

  // Mostra botão voltar em abas que não são home
  const backBtn = document.getElementById('backBtn');
  if(backBtn) backBtn.style.display = (page!=='home' && navHistory.length>1) ? 'flex' : 'none';

  const renderers={home:renderHome,events:renderEvents,users:renderUsers,groups:renderGroups,locais:renderLocais,history:renderHistoryPage,profile:renderProfile,setup:renderSetup};
  renderers[page]?.();
}

function goBack(){
  if(navHistory.length > 1){
    navHistory.pop(); // remove atual
    const prev = navHistory[navHistory.length-1] || 'home';
    // Navega sem adicionar ao histórico
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('page'+prev.charAt(0).toUpperCase()+prev.slice(1))?.classList.add('active');
    document.getElementById('nav-'+prev)?.classList.add('active');
    const backBtn = document.getElementById('backBtn');
    if(backBtn) backBtn.style.display = (prev!=='home' && navHistory.length>1) ? 'flex' : 'none';
    const renderers={home:renderHome,events:renderEvents,users:renderUsers,groups:renderGroups,locais:renderLocais,history:renderHistoryPage,profile:renderProfile,setup:renderSetup};
    renderers[prev]?.();
  } else {
    navigate('home');
  }
}

