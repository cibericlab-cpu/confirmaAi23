        <label class="fl">Mensagem</label>
        <textarea class="fi" id="reportMsg" rows="4" placeholder="Descreva seu problema ou dúvida em detalhes..." style="resize:none"></textarea>
      </div>
      <button class="btn btn-primary btn-full" onclick="submitReport()">📤 Enviar report</button>
    </div>
  </div>
</div>

