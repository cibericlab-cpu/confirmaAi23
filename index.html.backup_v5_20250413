  document.getElementById('csLabel').value='';
  document.getElementById('csEmoji').value='🏅';
  document.getElementById('csErr').textContent='';
  openModal('modalCustomSport');
}

function saveCustomSport(){
  const label = document.getElementById('csLabel').value.trim();
  const emoji = document.getElementById('csEmoji').value.trim()||'🏅';
  const err = document.getElementById('csErr');
  err.textContent='';
  if(!label){err.textContent='Informe o nome da modalidade';return;}
  // Gera key a partir do label
  const key = label.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'');
  if(!key){err.textContent='Nome inválido';return;}
  if(!state.customSports) state.customSports=[];
  if(state.customSports.find(s=>s.key===key)||key in SPORTS_BASE){
    err.textContent='Esta modalidade já existe';return;
  }
  state.customSports.push({key,label,emoji});
  saveLocal();
  refreshSPORTS();
  closeModal('modalCustomSport');
  renderCustomSports();
  renderSportPills();
  showToast(`Modalidade "${label}" adicionada! ${emoji}`,'ok');
}

function deleteCustomSport(key){
  state.customSports=(state.customSports||[]).filter(s=>s.key!==key);
  saveLocal();
  refreshSPORTS();
  renderCustomSports();
  renderSportPills();
  showToast('Modalidade removida','inf');
}

