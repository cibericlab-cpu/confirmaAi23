  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-title">🔄 Próxima Partida</div>
    <div class="modal-body">
      <div style="background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.2);border-radius:var(--r-sm);padding:12px;margin-bottom:16px;font-size:13px;color:var(--cyan);line-height:1.6">
        ♻️ Esta é uma partida recorrente. Confirme os dados para a próxima edição:
      </div>
      <input type="hidden" id="rcMatchId" />
      <div class="row2">
        <div class="fg"><label class="fl">Nova data</label><input class="fi" id="rcDate" type="date" /></div>
        <div class="fg"><label class="fl">Horário</label><input class="fi" id="rcStart" type="time" /></div>
      </div>
      <div class="fg"><label class="fl">Local</label><input class="fi" id="rcLocal" /></div>
      <div class="fg"><label class="fl">Abertura da lista</label>
        <select class="fi" id="rcOpenMode">
          <option value="now">Abrir imediatamente</option>
          <option value="scheduled">Agendar abertura</option>
          <option value="manual">Abertura manual pelo admin</option>
        </select>
      </div>
      <div id="rcScheduledDate" style="display:none">
        <div class="row2">
          <div class="fg"><label class="fl">Data abertura</label><input class="fi" id="rcOpenDate" type="date" /></div>
          <div class="fg"><label class="fl">Hora abertura</label><input class="fi" id="rcOpenTime" type="time" value="08:00" /></div>
        </div>
      </div>
      <button class="btn btn-primary btn-full" onclick="confirmRecurring()">✅ Criar nova edição</button>
      <button class="btn btn-ghost btn-full" style="margin-top:8px" onclick="closeModal('modalRecurringConfirm')">Deixar para depois</button>
    </div>
  </div>
</div>

<!-- Modal: Agendar Abertura da Lista -->
<div class="overlay" id="modalScheduleOpen" onclick="closeModal('modalScheduleOpen')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-title">📅 Agenda da Lista</div>
    <div class="modal-body">
      <input type="hidden" id="soMatchId" />
      <div id="soMatchTitle" style="background:var(--bg4);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:14px;font-size:13px;font-weight:600;color:var(--cyan)"></div>

      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">🔓 ABERTURA DA LISTA</div>
      <div class="toggle-row" style="margin-bottom:8px">
        <div class="toggle-info"><div class="toggle-label">Abrir lista agora</div><div class="toggle-desc">Jogadores já podem se inscrever</div></div>
        <label class="toggle"><input type="checkbox" id="soOpenNow" onchange="toggleScheduleMode()" checked><span class="toggle-track"></span></label>
      </div>
      <div id="soDateFields" style="display:none;margin-bottom:12px">
        <div class="row2">
          <div class="fg"><label class="fl">Data de abertura</label><input class="fi" id="soDate" type="date" /></div>
          <div class="fg"><label class="fl">Hora de abertura</label><input class="fi" id="soTime" type="time" value="08:00" /></div>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">📌 Status ficará como "Fechada" até esta data/hora.</div>
      </div>

      <div style="border-top:1px solid var(--border);margin:12px 0"></div>
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">⏰ ENCERRAMENTO DA LISTA</div>
      <div class="toggle-row" style="margin-bottom:8px">
        <div class="toggle-info"><div class="toggle-label">Encerrar lista automaticamente</div><div class="toggle-desc">Bloqueia novas inscrições num horário</div></div>
        <label class="toggle"><input type="checkbox" id="soCloseEnable" onchange="toggleCloseSched()"><span class="toggle-track"></span></label>
      </div>
      <div id="soCloseFields" style="display:none;margin-bottom:12px">
        <div class="fg"><label class="fl">Hora de encerramento (no dia da partida)</label><input class="fi" id="soCloseTime" type="time" value="20:00" /></div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">📌 Após este horário, a lista é bloqueada automaticamente.</div>
      </div>

      <button class="btn btn-primary btn-full" style="margin-top:8px" onclick="saveScheduleOpen()">💾 Salvar agenda</button>
    </div>
  </div>
</div>

