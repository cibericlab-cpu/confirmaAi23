   WORKER API — comunicação segura via proxy Cloudflare
   Token Baserow NUNCA sai do servidor
   ═════════════════════════════════════════════════════════ */
async function wFetch(resource, method='GET', body=null, params=''){
  // Usa /api/ local (Netlify Function) ou Worker externo
  const base = cfg.useNetlify ? '' : (cfg.workerUrl || '');
  const url = `${base}/api/${resource}${params ? '?' + params : ''}`;
  try{
    const opts={
      method,
      headers:{
        'Content-Type':'application/json',
        'X-App-Secret': cfg.appSecret
      }
    };
    if(body) opts.body=JSON.stringify(body);
    const r=await fetch(url,opts);
    if(!r.ok){
      const txt=await r.text().catch(()=>'');
      console.warn(`API [${method} ${resource}] ${r.status}:`,txt);
      return null;
    }
    return await r.json();
  }catch(e){console.error('API error:',e);return null}
}
async function wList(resource,params=''){return wFetch(resource,'GET',null,params)}
async function wCreate(resource,data){return wFetch(resource,'POST',data)}
async function wUpdate(resource,rowId,data){return wFetch(`${resource}/${rowId}`,'PATCH',data)}
async function wDelete(resource,rowId){return wFetch(`${resource}/${rowId}`,'DELETE')}

async function testWorker(){
