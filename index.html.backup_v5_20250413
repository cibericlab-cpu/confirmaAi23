/* ─── Status helpers ─────────────────────────────────── */
function isMatchVisible(m){
  // Oculta partidas encerradas (done/cancelled) e drafts ainda não abertas
  if(m.status==='cancelled') return false;  // canceladas ficam ocultas
  if(m.done) return false;                  // encerradas ocultas na home
  if(m.status==='draft') return false;      // agendadas ocultas até hora de abertura
  return true;
}

function isMatchVisibleAdmin(m){
  // Admin vê tudo exceto canceladas (se quiser pode incluir)
  return true;
}

/* ─── Auto-close engine ──────────────────────────────── */
async function checkAutoCloseMatches(){
  const now = Date.now();
  const nowDate = new Date(now);
  let changed = false;

  (state.matches||[]).forEach(m=>{
    if(m.status==='cancelled') return;

    // 1. Abre lista agendada (draft → open)
    if(m.status==='draft' && m.scheduledOpenAt){
      if(now >= new Date(m.scheduledOpenAt).getTime()){
        m.status='open'; m.scheduledOpenAt=null;
        addNotif(`🔓 Lista de "${m.title}" aberta automaticamente!`);
        changed=true;
      }
    }

    // 2. Encerra lista (closeListAt)
    if(m.status==='open' && !m.done && m.closeListAt && m.date){
      const closeStr=`${m.date}T${m.closeListAt}:00`;
      if(now >= new Date(closeStr).getTime() && !m.listClosed){
        m.listClosed=true;
        addNotif(`⏰ Lista de "${m.title}" encerrada — inscrições fechadas.`);
        changed=true;
      }
    }

    // 3. Encerra partida ao passar data+hora de fim
    if(m.done || !m.date) return;
    const endStr = m.end ? `${m.date}T${m.end}:00` : `${m.date}T23:59:59`;
    if(now <= new Date(endStr).getTime()) return; // ainda não venceu
    if(m._autoClosedAt) return; // já processou

    const isRec = m.recurring && m.recurring!=='none';

    if(isRec){
      // Recorrente: encerra, grava histórico, cria próxima edição como DRAFT oculta
      m.done=true; m.status='done'; m._autoClosedAt=now;
      saveMatchSnapshot(m);
      changed=true;

      const nextDate = calcNextRecurringDate(m);
      const nextOpen = m.scheduledOpenAt
        ? m.scheduledOpenAt.replace(/\d{4}-\d{2}-\d{2}/, nextDate)
        : null;

      const nextM = Object.assign({}, m, {
        id: genId(), brId: null,
        date: nextDate,
        status: nextOpen ? 'draft' : 'draft',
        scheduledOpenAt: nextOpen,
        done: false, _autoClosedAt: null,
        _recurringEndNotified: false, _recurringNotified: false,
        entries: [], listClosed: false,
        createdAt: now, _fromBR: false
      });
      state.matches.unshift(nextM);
      addNotif(`🔄 "${m.title}" encerrada. Próxima edição criada para ${new Date(nextDate+'T00:00:00').toLocaleDateString('pt-BR')} (lista fechada${nextOpen?' — abre em '+new Date(nextOpen).toLocaleString('pt-BR'):''})`);

    } else {
      // Única: encerra, histórico, notifica criador
      m.done=true; m.status='done'; m._autoClosedAt=now;
      saveMatchSnapshot(m);
      addNotif(`🏁 Partida "${m.title}" encerrada automaticamente e gravada no Histórico. Para jogar novamente, crie uma nova partida! 💪`);
      changed=true;
    }
  });

  if(changed){ saveLocal(); if(typeof render==='function') render(); }
}

