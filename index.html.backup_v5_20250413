function selectAvatar(el){
  document.querySelectorAll('#epAvatarGrid .avatar-opt').forEach(e=>e.classList.remove('sel'));
  el.classList.add('sel');
  const preview = document.getElementById('epAvatarPreview');
  if(preview) preview.textContent = el.dataset.av;
}

async function saveEditProfile(){
  const nome  = document.getElementById('epNome').value.trim();
  const senha = document.getElementById('epSenha').value;
  const senha2= document.getElementById('epSenha2').value;
  const sports= [...document.querySelectorAll('#epSports .sel')].map(e=>e.dataset.sport);
  const avatar= document.querySelector('#epAvatarGrid .sel')?.dataset.av || session?.avatar || '';
  const errEl = document.getElementById('epErr');
  errEl.textContent='';

  if(!nome){errEl.textContent='Nome não pode ser vazio';return}
  const nomeErrPerfil = validateName(nome);
  if(nomeErrPerfil){errEl.style.color='var(--red)';errEl.textContent=nomeErrPerfil;return}
  if(senha && senha!==senha2){errEl.textContent='As senhas não coincidem';return}
  if(senha && senha.length<4){errEl.textContent='Senha deve ter ao menos 4 caracteres';return}

  const updates = {nome, modalidades: sports.join(','), avatar};
  if(senha) updates.senha = senha;

  if(session?.brId && cfg.workerUrl){
    const ok = await wUpdate('usuarios', session.brId, updates);
    if(!ok){errEl.textContent='Erro ao salvar. Tente novamente.';return}
  }

  session.nome   = nome;
  session.sports = sports;
  session.avatar = avatar;
  if(senha) session.senha = senha;
  saveLocal();

  const u = state.users.find(u=>u.id===session.id);
  if(u){u.nome=nome;u.sports=sports;u.avatar=avatar;if(senha) u.senha=senha;}
  saveLocal();

  closeModal('modalEditProfile');
  const ab=document.getElementById('avatarBtn');
  if(ab) ab.textContent = session?.avatar || '👤';
  showToast('Perfil atualizado! ✅','ok');
  renderProfile();
}

