let teamSize = 5;
let generatedTeams = [];

function setTeamSize(n, el){
  teamSize = n;
  document.querySelectorAll('#teamSizeOpts .timer-preset').forEach(e=>e.classList.remove('sel'));
  el.classList.add('sel');
}

function shuffleTeamsForMatch(matchId){
  currentToolMatchId = matchId;
  const m = state.matches.find(m=>m.id===matchId);
  if(!m) return;
  openModal('modalTeams');
  shuffleTeams();
}

const TEAM_COLORS = ['#00FF87','#00D4FF','#FFB020','#FF3D5A','#B57BFF','#FF6B6B','#4DB8FF','#FF9F43'];
const TEAM_NAMES  = ['A','B','C','D','E','F','G','H'];

function shuffleTeams(){
  const m = state.matches.find(m=>m.id===currentToolMatchId);
  let players = m ? (m.entries||[]).filter(e=>e.status!=='desisted').map(e=>e.name)
                  : [];
  if(!players.length){
    document.getElementById('teamsResult').innerHTML=`<div class="empty" style="padding:20px"><div class="empty-ico">👥</div><div class="empty-title">Sem jogadores</div><div class="empty-desc">Adicione jogadores à partida primeiro.</div></div>`;
    return;
  }
  // Embaralha
  players = [...players].sort(()=>Math.random()-.5);
  const nTeams = Math.ceil(players.length / teamSize);
  generatedTeams = Array.from({length:nTeams},(_,i)=>({
    name: TEAM_NAMES[i]||String.fromCharCode(65+i),
    color: TEAM_COLORS[i%TEAM_COLORS.length],
    players: players.slice(i*teamSize,(i+1)*teamSize)
  }));
  renderTeamsResult();
}

function renderTeamsResult(){
  let h='';
  generatedTeams.forEach(t=>{
    h+=`<div class="team-card">
      <div class="team-header">
        <div class="team-badge" style="background:${t.color}">T${t.name}</div>
        <span>Time ${t.name}</span>
        <span style="font-size:13px;color:var(--muted);font-weight:400;margin-left:auto">${t.players.length} jogadores</span>
      </div>
      ${t.players.map(p=>`<div class="team-player">👤 ${p}</div>`).join('')}
    </div>`;
  });
  document.getElementById('teamsResult').innerHTML = h || '<div style="color:var(--muted);text-align:center;padding:20px">Clique em Sortear</div>';
}

function showMatchups(){
  if(!generatedTeams.length){shuffleTeams();return;}
  let h='<div style="font-weight:700;font-size:14px;margin-bottom:12px">📋 Todos contra todos:</div>';
  const rounds=[];
  for(let i=0;i<generatedTeams.length;i++){
    for(let j=i+1;j<generatedTeams.length;j++){
      rounds.push([generatedTeams[i],generatedTeams[j]]);
    }
  }
  rounds.forEach((r,idx)=>{
    h+=`<div class="matchup-row">
      <div class="team-badge" style="background:${r[0].color};width:28px;height:28px;border-radius:6px;font-size:12px">T${r[0].name}</div>
