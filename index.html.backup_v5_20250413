async function approveUser(userId){
  const u=state.users.find(u=>u.id===userId);
  if(!u) return;
  u.aprovado=true;u.ativo=true;
  if(u.brId&&cfg.workerUrl) await wUpdate('usuarios',u.brId,{aprovado:true,ativo:true});
  saveLocal();renderUsers();
  addNotif(`✅ ${u.nome} aprovado!`);
  showToast(`${u.nome} aprovado e liberado! ✅`,'ok');
}

async function rejectUser(userId){
  if(!confirm('Recusar e excluir este cadastro?')) return;
  const u=state.users.find(u=>u.id===userId);
  if(!u) return;
  if(u.brId&&cfg.workerUrl) await wDelete('usuarios',u.brId);
  state.users=state.users.filter(u=>u.id!==userId);
  saveLocal();renderUsers();
  showToast('Cadastro recusado','err');
}

