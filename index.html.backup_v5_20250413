/* ═════════════════════════════════════════════════════════
   FILTRO DE PALAVRÕES / CONTEÚDO OFENSIVO
   ═════════════════════════════════════════════════════════ */
const BAD_WORDS = [
  // PT-BR
  'porra','merda','caralho','puta','viado','bicha','cuzao','cuzão','buceta','pau',
  'fdp','filha da puta','vai se foder','arrombado','babaca','bosta','idiota',
  'otario','otário','imbecil','retardado','cretino','piranha','vagabundo',
  'negro','preto','macaco','judeu','cigano','nordestino',// termos racistas em contexto ofensivo
  'nazista','hitler','fascista',
  // Variações com números/símbolos comuns
  'c4ralho','m3rda','p0rra',
  // EN básico
  'fuck','shit','asshole','nigger','bitch','cunt','bastard','dickhead',
];

function containsBadWord(text){
  if(!text) return false;
  const normalized = text.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'') // remove acentos
    .replace(/[_\-\.]/g,' ') // trata separadores como espaço
    .replace(/0/g,'o').replace(/1/g,'i').replace(/3/g,'e').replace(/4/g,'a').replace(/5/g,'s');
  return BAD_WORDS.some(w => {
    const wn = w.normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    return normalized.includes(wn);
  });
}

function validateName(name){
  if(!name || name.trim().length < 2) return 'Nome deve ter pelo menos 2 caracteres.';
  if(containsBadWord(name)) return '❌ Nome não permitido. Use um nome respeitoso e adequado.';
  if(/[<>\"\';&{}]/.test(name)) return '❌ Nome contém caracteres inválidos.';
  return null; // válido
}

