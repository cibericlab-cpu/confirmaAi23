function renderHome(){
  const c=document.getElementById('pageHome');

  // Run auto-close check on render
  checkAutoCloseMatches();

  const all = filteredMatches();

  // Filtragem: home só mostra partidas ABERTAS e AGENDADAS PARA ABRIR
  // Encerradas/canceladas/drafts são ocultas (exceto admin que vê tudo em "Partidas")
  const visible = isAdmin()
    ? all.filter(m=>!m.done && m.status!=='cancelled')
    : all.filter(m=>m.status==='open' && !m.done && !m.listClosed===false);

  // Partidas abertas
  const openMatches = visible.filter(m=>m.status==='open' && !m.done);
  // Partidas agendadas (draft com scheduledOpenAt)
  const scheduledMatches = isAdmin()
    ? all.filter(m=>m.status==='draft' && !m.done)
    : [];

  const myEntries=state.matches.reduce((a,m)=>a+(m.entries||[]).filter(e=>e.userId===session?.id&&e.status!=='desisted').length,0);
  const totalConf=state.matches.reduce((a,m)=>a+(m.entries||[]).filter(e=>e.status!=='desisted').length,0);

  let h=`<div class="stats-row" style="padding-top:8px">
    <div class="stat-card"><div class="stat-num">${openMatches.length}</div><div class="stat-lbl">Abertas</div></div>
