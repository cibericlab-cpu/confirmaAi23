/* ═════════════════════════════════════════════════════════
   MATCH CARD
   ═════════════════════════════════════════════════════════ */
function matchCard(m, forceExpand=false){
  const confirmed=(m.entries||[]).filter(e=>e.type==='confirmed'&&e.status!=='desisted');
  const quorum=(m.entries||[]).filter(e=>e.type==='quorum'&&e.status!=='desisted');
  const waiting=(m.entries||[]).filter(e=>e.type==='waiting'&&e.status!=='desisted');
  const desisted=(m.entries||[]).filter(e=>e.status==='desisted');
  const total=confirmed.length+quorum.length;
  const maxTotal=m.minPlayers||m.maxPlayers;
  const pct=Math.min((total/maxTotal)*100,100);
  const progClass=pct>=100?'red-fill':pct>=70?'amber-fill':'';
  const hasQuorum=total>=m.minPlayers;
  const sport=SPORTS[m.sport]||{emoji:'🏅',label:'Outro'};
  const cancelled=m.status==='cancelled';
  const dateStr=m.date?new Date(m.date+'T00:00:00').toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'short'}):'';
  const recLabel=m.recurring&&m.recurring!=='none'?`🔄 ${RECURRENCE[m.recurring]}`:'';
  const myEntry=(m.entries||[]).find(e=>e.userId===session?.id&&e.status!=='desisted');
  const accClass=cancelled?'red':m.done?'amber':'';
  const expanded = forceExpand || (state.expandedCards||{})[m.id];
  const canManage = isAdmin()||(session?.canCreateMatch&&m.createdBy===session?.id);

  // ── CABEÇALHO (sempre visível) ──────────────────────────
  let h=`<div class="card" id="mc_${m.id}">
    ${accClass?`<div class="card-accent ${accClass}"></div>`:`<div class="card-accent"></div>`}
    ${cancelled?`<div class="cancelled-banner">🚫 PARTIDA CANCELADA 🚫</div>`:''}
    <div class="match-hdr" onclick="toggleCardExpand('${m.id}')" style="cursor:pointer">
      <div class="match-sport">${sport.emoji}</div>
      <div class="match-info" style="flex:1">
        <div class="match-title">${m.title}</div>
        <div class="match-subtitle">
          <span class="status-badge ${cancelled?'status-cancelled':m.done?'status-closed':'status-open'}">${cancelled?'Cancelada':m.done?'Encerrada':'Aberta'}</span>
          ${recLabel?`<span class="status-badge status-recurring">${recLabel}</span>`:''}
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0">
        <div style="font-size:11px;color:var(--muted)">${dateStr}</div>
        <div style="font-size:11px;font-weight:700;color:${hasQuorum?'var(--green)':'var(--amber)'}">
          ${total}/${maxTotal} ${hasQuorum?'✅':'⚠️'}
        </div>
      </div>
    </div>`;

  // ── RESUMO COMPACTO (sempre visível) ────────────────────
  h+=`<div style="padding:8px 14px 8px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)">
    <div class="prog-track" style="flex:1;height:4px">
      <div class="prog-fill ${progClass}" style="width:${pct}%"></div>
    </div>
    ${m.start?`<div style="font-size:11px;color:var(--muted)">🕒 ${m.start}</div>`:''}
    ${myEntry?`<div style="font-size:11px;font-weight:700;color:var(--green)">✓ Na lista</div>`:''}
    <button onclick="toggleCardExpand('${m.id}')" style="background:none;border:1px solid var(--border2);border-radius:50px;padding:3px 10px;color:var(--muted);font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap">
      ${expanded?'▲ Menos':'▼ Ver mais'}
    </button>
  </div>`;

  // ── DETALHES EXPANDIDOS ─────────────────────────────────
  if(expanded){
    h+=`<div class="match-meta">
      ${dateStr?`<div class="meta-chip">📅 <strong>${m.date?new Date(m.date+'T00:00:00').toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'}):''}</strong></div>`:''}
      ${(m.start||m.end)?`<div class="meta-chip">🕒 <strong>${m.start||'?'}${m.end?' – '+m.end:''}</strong></div>`:''}
      ${m.local?`<div class="meta-chip link" onclick="openMap('${m.mapUrl||''}','${m.local}')">📍 <strong>${m.local}</strong> ↗</div>`:''}
      ${m.taxa?`<div class="meta-chip">💰 <strong>R$ ${parseCurrency(m.taxa).toFixed(2)}</strong>/pessoa</div>`:(m.gratuito?`<div class="meta-chip" style="color:var(--green)">✅ <strong>Gratuito</strong></div>`:'')}
      ${m.pix?`<div class="meta-chip link" onclick="copyPix('${m.pix}','${m.pixNome||''}')" style="color:var(--green);border-color:rgba(0,255,135,.25)">💸 PIX — toque para copiar</div>`:''}
      ${m.obs?`<div class="meta-chip" style="color:var(--amber)">⚠️ ${m.obs}</div>`:''}
    </div>
    <div class="prog-wrap">
      <div class="prog-labels">
        <span>${total} confirmados de ${maxTotal} necessários</span>
        <span>${hasQuorum?'<strong style="color:var(--green)">✅ Quórum OK</strong>':'<span style="color:var(--amber)">⚠️ Sem quórum</span>'}</span>
      </div>
      <div class="prog-track"><div class="prog-fill ${progClass}" style="width:${pct}%"></div></div>
    </div>
    <div class="plist">`;

    h+=renderPlayerSection(m,'confirmed','Confirmados',confirmed,m.maxPlayers);
    if(m.minPlayers>m.maxPlayers){
      h+=renderPlayerSection(m,'quorum','▸ Quórum mínimo',quorum,m.minPlayers-m.maxPlayers,'a');
    }
    if(waiting.length||(!cancelled&&!m.done)){
      h+=renderPlayerSection(m,'waiting','Lista de Reserva',waiting,m.reserveSlots||5,'');
    }
    if(desisted.length){
      h+=`<div class="section-sep" style="color:var(--red)">Desistências (${desisted.length})</div>`;
      desisted.slice(0,3).forEach(e=>{
        h+=`<div class="player-row desisted"><div class="player-num r">✗</div><div class="player-name deist">${e.name}</div></div>`;
      });
    }

    if(!cancelled&&!m.done){
      if(!myEntry){
        if(!isAdmin()){
          h+=`<button class="btn btn-primary btn-full" onclick="joinMatch('${m.id}')">Confirmar presença</button>`;
        } else {
          h+=`<div class="add-row">
            <input class="add-inp" id="ai_${m.id}" placeholder="Nome do jogador..." onkeydown="if(event.key==='Enter')addPlayerAdmin('${m.id}')"/>
            <button class="add-btn" onclick="addPlayerAdmin('${m.id}')">+</button>
          </div>`;
        }
      } else {
        if(!isAdmin()&&myEntry){
          h+=`<button class="btn btn-danger btn-full" onclick="leaveMatch('${m.id}')">❌ Desistir da partida</button>`;
        }
        if(isAdmin()){
          h+=`<div class="add-row">
            <input class="add-inp" id="ai_${m.id}" placeholder="Nome do jogador..." onkeydown="if(event.key==='Enter')addPlayerAdmin('${m.id}')"/>
            <button class="add-btn" onclick="addPlayerAdmin('${m.id}')">+</button>
          </div>`;
        }
      }
    }

    h+=`</div>
    <div class="match-actions">
      <div class="btn btn-ghost btn-icon" onclick="openShare('${m.id}')">📤</div>
      <div class="btn btn-ghost btn-icon" onclick="openMatchTools('${m.id}')">🛠️</div>
      <div class="btn btn-ghost btn-icon" onclick="openHistory('${m.id}')">📋</div>
      ${canManage?`
        <div class="btn btn-ghost btn-icon" onclick="openEditMatch('${m.id}')">✏️</div>
        <div class="btn btn-ghost btn-icon" onclick="openScheduleOpen('${m.id}')">📅</div>
        <div class="btn btn-ghost btn-icon" onclick="toggleCancelMatch('${m.id}')">${cancelled?'🔄':'🚫'}</div>
        <div class="btn btn-ghost btn-icon" onclick="toggleDoneMatch('${m.id}')">${m.done?'🔄':'🏁'}</div>
        <div class="btn btn-danger btn-icon" onclick="deleteMatch('${m.id}')">🗑️</div>
      `:`<div style="flex:1"></div>`}
    </div>`;
  } else {
    // Ações rápidas mesmo colapsado
    h+=`<div style="padding:8px 14px;display:flex;gap:6px">
      ${!cancelled&&!m.done&&!myEntry&&!isAdmin()?`<button class="btn btn-primary" style="flex:1;padding:9px" onclick="joinMatch('${m.id}')">Confirmar presença</button>`:''}
      ${!cancelled&&!m.done&&myEntry&&!isAdmin()?`<button class="btn btn-danger" style="flex:1;padding:9px" onclick="leaveMatch('${m.id}')">❌ Desistir</button>`:''}
      ${myEntry&&m.taxa?`<button class="btn btn-ghost btn-icon" onclick="openPayment('${m.id}','${myEntry.id}')" title="Pagamento">${myEntry.paid?'⭐':'💵'}</button>`:''}
      <div class="btn btn-ghost btn-icon" onclick="openShare('${m.id}')">📤</div>
      <div class="btn btn-ghost btn-icon" onclick="openMatchTools('${m.id}')">🛠️</div>
      ${canManage?`<div class="btn btn-ghost btn-icon" onclick="toggleCardExpand('${m.id}')">✏️</div>`:''}
    </div>`;
  }

  h+=`</div>`;
  return h;
}

function toggleCardExpand(matchId){
  if(!state.expandedCards) state.expandedCards={};
  state.expandedCards[matchId] = !state.expandedCards[matchId];
  // Re-render só este card
  const el=document.getElementById(`mc_${matchId}`);
  const m=state.matches.find(m=>m.id===matchId);
  if(el&&m){ el.outerHTML=matchCard(m); }
}

function renderPlayerSection(m,type,label,list,maxSlots,numClass='g'){
  const slots=maxSlots||0;
  let h=`<div class="section-sep">${label} <span style="color:var(--green)">(${list.length}/${slots})</span></div>`;
  for(let i=0;i<slots;i++){
    const e=list[i];
    if(e){
      const isPaid=e.paid;
      const hasReceipt=!!e.receiptUrl;
      const payTip=isPaid?'✅ Pago':'💳 Confirmar pagamento';
      const canPay=isAdmin()||(e.userId===session?.id);
      h+=`<div class="player-row confirmed">
        <div class="player-num ${numClass||'g'}">${i+1}</div>
        <div class="player-name">${e.name}</div>
        ${m.taxa&&canPay?`<button class="pay-btn ${isPaid?'paid':''} ${hasReceipt?'has-receipt':''}" onclick="openPayment('${m.id}','${e.id}')" title="${payTip}">${isPaid?'⭐':'💵'}</button>`:''}
        ${isAdmin()?`<div class="row-actions">
          <button class="mini-btn up" onclick="promoteEntry('${m.id}','${e.id}')" title="Promover">⬆️</button>
          <button class="mini-btn rm" onclick="removeEntry('${m.id}','${e.id}')">✕</button>
        </div>`:(!isAdmin()&&e.userId===session?.id?`<button class="mini-btn rm" onclick="leaveMatch('${m.id}')">✕</button>`:'')}
      </div>`;
    } else {
      h+=`<div class="player-row" style="opacity:.28"><div class="player-num">${i+1}</div><div class="player-name" style="color:var(--muted2)">— vaga livre —</div></div>`;
    }
  }
  return h;
}

