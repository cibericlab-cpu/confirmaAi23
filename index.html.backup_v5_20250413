async function togglePlayerPermission(userId, canCreate){
  const u = state.users.find(u=>u.id===userId);
  if(!u) return;
  u.canCreateMatch = canCreate;
  // Atualiza no Baserow se tiver campo "pode_criar_partida"
  // (adicione este campo Boolean na tabela USUARIOS se quiser persistir)
  if(u.brId && cfg.workerUrl){
    await wUpdate('usuarios', u.brId, {pode_criar_partida: canCreate});
  }
  saveLocal();
  showToast(`${u.nome}: ${canCreate?'pode criar partidas ✅':'não pode criar partidas'}`, 'ok');
  // Se o usuário logado for afetado, atualiza o FAB
  if(session?.id === userId){
    session.canCreateMatch = canCreate;
    document.getElementById('fabBtn').style.display = (isAdmin()||canCreate)?'flex':'none';
  }
}

