}

async function saveEditMatch(){
  const matchId=document.getElementById('eMatchId').value;
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const chargeTax=document.getElementById('eChargeTax').checked;
  m.title=document.getElementById('eTitle').value.trim()||m.title;
  m.date=document.getElementById('eDate').value;
  m.recurring=document.getElementById('eRecurring').value;
  m.start=document.getElementById('eStart').value;
  m.end=document.getElementById('eEnd').value;
  m.local=document.getElementById('eLocal').value.trim();
  m.mapUrl=document.getElementById('eMapUrl').value.trim();
  m.maxPlayers=parseInt(document.getElementById('eMax').value)||m.maxPlayers;
  m.minPlayers=parseInt(document.getElementById('eMin').value)||m.minPlayers;
  m.reserveSlots=parseInt(document.getElementById('eReserve').value)||m.reserveSlots;
  m.gratuito=!chargeTax;
  m.taxa=chargeTax?String(parseCurrency(document.getElementById('eTaxa').value)):'';
