    <div class="stat-card"><div class="stat-num">${totalConf}</div><div class="stat-lbl">Confirmados</div></div>
  </div>`;

  if(!openMatches.length && !scheduledMatches.length){
    h+=`<div class="empty"><div class="empty-ico">⚽</div><div class="empty-title">Nenhuma partida aberta</div>
    <div class="empty-desc">${isAdmin()?'Toque em + para criar uma partida!':'Aguarde o admin abrir uma partida.'}</div></div>`;
    c.innerHTML=h; return;
  }

  if(openMatches.length){
    h+=`<div class="sec-hdr"><div class="sec-title">Partidas Abertas</div></div>`;
    openMatches.forEach(m=>{h+=matchCard(m)});
  }

  if(scheduledMatches.length){
    h+=`<div class="sec-hdr"><div class="sec-title">⏰ Agendadas (somente admin)</div></div>`;
    scheduledMatches.forEach(m=>{h+=matchCard(m)});
  }

  c.innerHTML=h;
}

