   RECORRÊNCIA — confirmar próxima edição
   ═════════════════════════════════════════════════════════ */
function openRecurringConfirm(matchId){
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  document.getElementById('rcMatchId').value=matchId;
  // Calcula próxima data
  const nextDate = calcNextRecurringDate(m);
  document.getElementById('rcDate').value=nextDate;
  document.getElementById('rcStart').value=m.start||'';
  document.getElementById('rcLocal').value=m.local||'';
  document.getElementById('rcOpenMode').value='now';
  document.getElementById('rcScheduledDate').style.display='none';
  document.getElementById('rcOpenMode').onchange=function(){
    document.getElementById('rcScheduledDate').style.display=this.value==='scheduled'?'':'none';
  };
  openModal('modalRecurringConfirm');
}

function calcNextRecurringDate(m){
  if(!m.date) return '';
  const d = new Date(m.date+'T00:00:00');
  const map={weekly:7,biweekly:14,monthly:30};
  const days=map[m.recurring]||7;
  d.setDate(d.getDate()+days);
  return d.toISOString().split('T')[0];
}

async function confirmRecurring(){
  const matchId=document.getElementById('rcMatchId').value;
  const m=state.matches.find(m=>m.id===matchId);
  if(!m) return;
  const newDate=document.getElementById('rcDate').value;
  const newStart=document.getElementById('rcStart').value;
  const newLocal=document.getElementById('rcLocal').value;
  const openMode=document.getElementById('rcOpenMode').value;
  const openDate=openMode==='scheduled'?document.getElementById('rcOpenDate').value:'';
  const openTime=openMode==='scheduled'?document.getElementById('rcOpenTime').value:'';

  // Cria nova partida baseada na recorrente
  const newMatch={...m,
    id:genId(),brId:null,
    date:newDate,start:newStart||m.start,local:newLocal||m.local,
    status:openMode==='manual'?'draft':'open',
    scheduledOpenAt:openMode==='scheduled'?`${openDate}T${openTime}`:null,
    done:false,entries:[],createdAt:Date.now(),_fromBR:false
  };
  state.matches.unshift(newMatch);

  if(cfg.workerUrl&&cfg.appSecret){
    const br=await wCreate('partidas',{
      titulo:newMatch.title,esporte:newMatch.sport,data:newDate,
      horario_inicio:newMatch.start,horario_fim:newMatch.end,
      local:newMatch.local,mapa_url:newMatch.mapUrl,
      vagas_principais:newMatch.maxPlayers,quorum_minimo:newMatch.minPlayers,
      vagas_reserva:newMatch.reserveSlots,recorrencia:newMatch.recurring,
      tipo_lista:newMatch.listType,gratuito:newMatch.gratuito,
      taxa:parseCurrency(newMatch.taxa),pix:newMatch.pix,pix_nome:newMatch.pixNome,
      observacao:newMatch.obs,status:newMatch.status
    });
    if(br) newMatch.brId=br.id;
  }
  saveLocal();
  closeModal('modalRecurringConfirm');
  addNotif(`📅 Nova edição de "${m.title}" criada para ${new Date(newDate+'T00:00:00').toLocaleDateString('pt-BR')}`);
  showToast('Nova edição criada! 🎉','ok');
  navigate('home');
}

