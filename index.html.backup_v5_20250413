<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0A0F1A">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ConfirmaAí">
<link rel="manifest" href="manifest.json">
<link rel="icon" type="image/png" href="https://i.ibb.co/fYXRYLq4/logoconfai.png">
<link rel="apple-touch-icon" href="https://i.ibb.co/fYXRYLq4/logoconfai.png">
<title>ConfirmaAí</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ── RESET & TOKENS ───────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --g1:#00FF87;--g2:#00D4FF;--grd:linear-gradient(135deg,var(--g1),var(--g2));
  --bg:#0A0F1A;--bg2:#0F1626;--bg3:#141D2E;--bg4:#1A2540;--bg5:#202C48;
  --card:#131C2E;--card2:#192233;
  --text:#F0F6FF;--muted:#5A7090;--muted2:#3A5070;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.1);
  --red:#FF3D5A;--amber:#FFB020;--blue:#4DB8FF;--purple:#B57BFF;
  --green:#00FF87;--cyan:#00D4FF;
  --r:16px;--r-sm:10px;--r-xs:6px;
  --safe-b:env(safe-area-inset-bottom,0px);
  --font-title:'Barlow Condensed',sans-serif;
  --font-body:'Nunito',sans-serif;
}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100dvh;overflow-x:hidden;font-size:15px;line-height:1.5}
input,select,textarea,button{font-family:var(--font-body)}
a{color:inherit;text-decoration:none}
img{max-width:100%}

/* ── LAYOUT ────────────────────────────────────────────── */
.app{max-width:430px;margin:0 auto;position:relative;min-height:100dvh}
.page{display:none;animation:fadeUp .3s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── HEADER ────────────────────────────────────────────── */
.hdr{
  padding:16px 18px 0;position:sticky;top:0;z-index:80;
  background:linear-gradient(180deg,var(--bg) 70%,transparent);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
}
.hdr-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.logo-badge{
  width:38px;height:38px;border-radius:11px;
  background:var(--grd);display:flex;align-items:center;justify-content:center;
  font-family:var(--font-title);font-weight:900;font-size:20px;color:#0A0F1A;
  flex-shrink:0;
}
.logo-name{font-family:var(--font-title);font-weight:900;font-size:22px;letter-spacing:.5px}
.logo-name em{font-style:normal;background:var(--grd);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hdr-actions{display:flex;gap:8px}
.icon-btn{
  width:38px;height:38px;border-radius:50%;background:var(--bg4);
  border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;
  font-size:17px;cursor:pointer;position:relative;transition:.2s;flex-shrink:0;
}
.icon-btn:active{transform:scale(.88)}
.badge{
  position:absolute;top:-3px;right:-3px;min-width:17px;height:17px;
  padding:0 4px;border-radius:50px;background:var(--red);
  font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;
  border:2px solid var(--bg);color:#fff;
}

/* ── PILL TABS ─────────────────────────────────────────── */
.pill-scroll{
  display:flex;gap:7px;
  overflow-x:scroll;overflow-y:hidden;
  padding:0 18px 14px;
  scrollbar-width:none;
  -webkit-overflow-scrolling:touch;
  touch-action:pan-x pan-y;
  overscroll-behavior-x:contain;
  will-change:scroll-position;
  -ms-overflow-style:none;
  cursor:grab;
}
.pill-scroll:active{cursor:grabbing}
.pill-scroll::-webkit-scrollbar{display:none}
.pill{
  flex-shrink:0;padding:7px 15px;border-radius:50px;
  background:var(--bg4);border:1px solid var(--border);
  font-size:13px;font-weight:600;cursor:pointer;transition:.2s;
  white-space:nowrap;color:var(--muted);display:flex;align-items:center;gap:5px;
  user-select:none;-webkit-user-select:none;
}
.pill.active{background:var(--grd);color:#0A0F1A;border-color:transparent}
.pill:active{transform:scale(.94)}

/* ── CONTENT ────────────────────────────────────────────── */
.content{padding:0 14px 130px}

/* ── CARDS ─────────────────────────────────────────────── */
.card{
  background:var(--card);border-radius:var(--r);
  border:1px solid var(--border);margin-bottom:14px;overflow:hidden;position:relative;
}
.card::after{
  content:'';position:absolute;inset:0;border-radius:var(--r);
  background:linear-gradient(135deg,rgba(0,255,135,.04),transparent 60%);
  pointer-events:none;
}
.card-accent{position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--grd)}
.card-accent.red{background:var(--red)}
.card-accent.amber{background:var(--amber)}
.card-accent.purple{background:var(--purple)}

/* ── MATCH CARD ─────────────────────────────────────────── */
.match-hdr{padding:14px 14px 10px 18px;display:flex;align-items:flex-start;gap:10px;border-bottom:1px solid var(--border)}
.match-sport{font-size:28px;line-height:1;flex-shrink:0}
.match-info{flex:1;min-width:0}
.match-title{font-family:var(--font-title);font-weight:800;font-size:20px;letter-spacing:.3px;line-height:1.1;margin-bottom:4px}
.match-subtitle{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.status-badge{
  padding:3px 9px;border-radius:50px;font-size:10px;font-weight:800;
  letter-spacing:.5px;text-transform:uppercase;
}
.status-open{background:rgba(0,255,135,.12);color:var(--green)}
.status-closed{background:rgba(255,176,32,.12);color:var(--amber)}
.status-cancelled{background:rgba(255,61,90,.12);color:var(--red)}
.status-recurring{background:rgba(0,212,255,.12);color:var(--cyan)}

.match-meta{padding:10px 14px 10px 18px;display:flex;flex-wrap:wrap;gap:8px;border-bottom:1px solid var(--border)}
.meta-chip{
  display:flex;align-items:center;gap:5px;font-size:12px;color:var(--muted);
  background:var(--bg4);padding:4px 10px;border-radius:50px;border:1px solid var(--border);
}
.meta-chip strong{color:var(--text);font-weight:600}
.meta-chip.link{color:var(--cyan);cursor:pointer;border-color:rgba(0,212,255,.2)}
.meta-chip.link:active{transform:scale(.95)}

/* Cancelled overlay */
.cancelled-banner{
  background:linear-gradient(90deg,rgba(255,61,90,.9),rgba(180,0,40,.9));
  color:#fff;font-family:var(--font-title);font-weight:900;font-size:18px;
  letter-spacing:2px;text-align:center;padding:10px;
  transform:rotate(-1deg);margin:8px -2px;position:relative;z-index:5;
}

/* ── PROGRESS ───────────────────────────────────────────── */
.prog-wrap{padding:10px 14px 10px 18px}
.prog-labels{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px}
.prog-labels strong{color:var(--green);font-weight:700}
.prog-track{height:5px;background:var(--bg5);border-radius:10px;overflow:hidden}
.prog-fill{height:100%;border-radius:10px;background:var(--grd);transition:width .5s ease}
.prog-fill.amber-fill{background:linear-gradient(90deg,var(--amber),#FF8F00)}
.prog-fill.red-fill{background:linear-gradient(90deg,var(--red),#FF6B6B)}

/* ── PLAYER ROWS ────────────────────────────────────────── */
.plist{padding:0 14px 10px 18px}
.section-sep{
  font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;
  color:var(--muted2);margin:8px 0 6px;display:flex;align-items:center;gap:8px;
}
.section-sep::after{content:'';flex:1;height:1px;background:var(--border)}

.player-row{
  display:flex;align-items:center;gap:9px;padding:9px 10px;
  border-radius:var(--r-sm);background:var(--bg4);border:1px solid var(--border);
  margin-bottom:5px;transition:.2s;
}
.player-row.confirmed{border-color:rgba(0,255,135,.15)}
.player-row.waiting{border-color:rgba(255,176,32,.15);background:rgba(255,176,32,.04)}
.player-row.desisted{border-color:rgba(255,61,90,.1);opacity:.5}
.player-num{
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:800;background:var(--bg5);color:var(--muted);
}
.player-num.g{background:rgba(0,255,135,.12);color:var(--green)}
.player-num.a{background:rgba(255,176,32,.12);color:var(--amber)}
.player-num.r{background:rgba(255,61,90,.12);color:var(--red)}
.player-name{flex:1;font-size:13px;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.player-name.deist{text-decoration:line-through;color:var(--muted)}

/* Payment button */
.pay-btn{
  width:30px;height:30px;border-radius:50%;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:15px;
  background:var(--bg5);transition:.2s;flex-shrink:0;
}
.pay-btn:active{transform:scale(.85)}
.pay-btn.paid{background:rgba(0,255,135,.15);border:1px solid rgba(0,255,135,.3)}
.pay-btn.has-receipt{box-shadow:0 0 0 2px var(--cyan)}

.row-actions{display:flex;gap:5px}
.mini-btn{
  width:28px;height:28px;border-radius:50%;border:none;background:var(--bg5);
  cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;
  transition:.2s;flex-shrink:0;
}
.mini-btn:active{transform:scale(.85)}
.mini-btn.up{background:rgba(77,184,255,.1);color:var(--blue)}
.mini-btn.rm{background:rgba(255,61,90,.1);color:var(--red)}

/* Add player row */
.add-row{display:flex;gap:7px;margin-top:8px}
.add-inp{
  flex:1;padding:10px 13px;border-radius:var(--r-sm);
  background:var(--bg5);border:1px solid var(--border2);
  color:var(--text);font-size:13px;outline:none;transition:.2s;
}
.add-inp:focus{border-color:var(--green)}
.add-inp::placeholder{color:var(--muted2)}
.add-btn{
  width:42px;height:42px;border-radius:var(--r-sm);background:var(--grd);
  border:none;color:#0A0F1A;font-size:22px;font-weight:700;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:.2s;
}
.add-btn:active{transform:scale(.88)}

/* ── MATCH ACTIONS ──────────────────────────────────────── */
.match-actions{padding:10px 14px;display:flex;gap:7px;border-top:1px solid var(--border)}
.btn{
  padding:11px;border-radius:var(--r-sm);border:none;cursor:pointer;
  font-family:var(--font-body);font-size:13px;font-weight:700;
  transition:.2s;display:flex;align-items:center;justify-content:center;gap:5px;flex:1;
}
.btn:active{transform:scale(.96)}
.btn-primary{background:var(--grd);color:#0A0F1A}
.btn-ghost{background:var(--bg4);color:var(--text);border:1px solid var(--border2)}
.btn-danger{background:rgba(255,61,90,.12);color:var(--red);border:1px solid rgba(255,61,90,.2)}
.btn-warn{background:rgba(255,176,32,.12);color:var(--amber);border:1px solid rgba(255,176,32,.2)}
.btn-icon{width:42px;flex:none;padding:0}
.btn-full{width:100%;margin-top:10px;padding:15px;font-size:15px}

/* ── STATS ROW ──────────────────────────────────────────── */
.stats-row{display:flex;gap:8px;margin-bottom:14px}
.stat-card{
  flex:1;background:var(--card2);border-radius:var(--r-sm);
  border:1px solid var(--border);padding:12px;text-align:center;
}
.stat-num{font-family:var(--font-title);font-size:28px;font-weight:900;background:var(--grd);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}

/* ── SECTION HEADER ─────────────────────────────────────── */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 14px 8px}
.sec-title{font-family:var(--font-title);font-size:22px;font-weight:800;letter-spacing:.5px}
.sec-action{font-size:13px;color:var(--cyan);font-weight:700;cursor:pointer}

/* ── FAB ────────────────────────────────────────────────── */
.fab{
  position:fixed;bottom:calc(80px + var(--safe-b));right:16px;
  width:54px;height:54px;border-radius:16px;
  background:var(--grd);border:none;color:#0A0F1A;font-size:28px;
  cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:300;
  box-shadow:0 6px 28px rgba(0,255,135,.3);transition:.2s;z-index:100;
  font-family:var(--font-body);
}
.fab:active{transform:scale(.88)}

/* ── BOTTOM NAV ─────────────────────────────────────────── */
.bnav{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%);
  width:100%;max-width:430px;
  background:rgba(10,15,26,.95);border-top:1px solid var(--border2);
  padding:8px 4px calc(8px + var(--safe-b));
  display:flex;justify-content:space-around;z-index:90;
  backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
}
.nav-item{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  cursor:pointer;padding:4px 6px;border-radius:10px;transition:.2s;color:var(--muted);
  flex:1;min-width:0;
}
.nav-item.active{color:var(--green)}
.nav-ico{font-size:19px}
.nav-lbl{font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;white-space:nowrap}

/* ── MODALS ─────────────────────────────────────────────── */
.overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;
  display:flex;align-items:flex-end;opacity:0;pointer-events:none;
  transition:opacity .3s;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
}
.overlay.open{opacity:1;pointer-events:all}
.modal{
  width:100%;max-width:430px;margin:0 auto;
  background:var(--bg2);border-radius:24px 24px 0 0;
  max-height:92dvh;overflow-y:auto;
  transform:translateY(100%);transition:transform .35s cubic-bezier(.34,1.56,.64,1);
}
.overlay.open .modal{transform:translateY(0)}
.modal-handle{width:38px;height:4px;border-radius:2px;background:var(--bg5);margin:13px auto 18px}
.modal-title{font-family:var(--font-title);font-size:26px;font-weight:900;padding:0 20px 16px;letter-spacing:.5px}
.modal-body{padding:0 20px 48px}

/* ── FORM ───────────────────────────────────────────────── */
.fg{margin-bottom:14px}
.fl{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);margin-bottom:7px;display:block}
.fi{
  width:100%;padding:13px 14px;border-radius:var(--r-sm);
  background:var(--bg4);border:1px solid var(--border2);
  color:var(--text);font-size:14px;outline:none;transition:.2s;
}
.fi:focus{border-color:var(--green)}
.fi::placeholder{color:var(--muted2)}
select.fi{-webkit-appearance:none;appearance:none}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

/* Toggle switch */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--bg4);border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:14px}
.toggle-info{flex:1}
.toggle-label{font-size:14px;font-weight:600}
.toggle-desc{font-size:11px;color:var(--muted);margin-top:2px}
.toggle{position:relative;width:46px;height:26px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0}
.toggle-track{
  position:absolute;inset:0;background:var(--bg5);border-radius:50px;cursor:pointer;transition:.3s;
  border:1px solid var(--border2);
}
.toggle input:checked~.toggle-track{background:var(--green);border-color:var(--green)}
.toggle-track::before{
  content:'';position:absolute;left:3px;top:50%;transform:translateY(-50%);
  width:18px;height:18px;border-radius:50%;background:#fff;transition:.3s;
}
.toggle input:checked~.toggle-track::before{transform:translate(20px,-50%)}

/* Sport grid */
.sport-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.sport-opt{
  padding:12px 6px;border-radius:var(--r-sm);background:var(--bg4);
  border:1px solid var(--border);text-align:center;cursor:pointer;transition:.2s;
  font-size:11px;color:var(--muted);font-weight:600;
}
.sport-opt .se{font-size:22px;display:block;margin-bottom:3px}
.sport-opt.sel{border-color:var(--green);background:rgba(0,255,135,.08);color:var(--green)}
.sport-opt:active{transform:scale(.94)}

/* ── INSTALL BANNER ─────────────────────────────────────── */
#installBanner{
  position:fixed;bottom:calc(76px + var(--safe-b));left:12px;right:12px;
  background:var(--bg2);border:1px solid rgba(0,255,135,.25);border-radius:var(--r);
  padding:14px 16px;display:flex;align-items:center;gap:12px;z-index:300;
  transform:translateY(120px);opacity:0;transition:transform .4s cubic-bezier(.34,1.56,.64,1),opacity .4s ease;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
}
#installBanner .ib-icon{font-size:28px;flex-shrink:0}
#installBanner .ib-text{flex:1}
#installBanner .ib-title{font-weight:700;font-size:14px;margin-bottom:2px}
#installBanner .ib-sub{font-size:11px;color:var(--muted)}
#installBanner .ib-btn{
  padding:10px 16px;border-radius:var(--r-sm);background:var(--grd);
  border:none;color:#0A0F1A;font-weight:800;font-size:13px;cursor:pointer;flex-shrink:0;
  transition:.2s;
}
#installBanner .ib-btn:active{transform:scale(.92)}
#installBanner .ib-close{
  width:28px;height:28px;border-radius:50%;background:var(--bg4);border:none;
  color:var(--muted);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}

/* ── SPLASH SCREEN ──────────────────────────────────────── */
#splashScreen{
  position:fixed;inset:0;z-index:9999;
  background:#0A0F1A;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity .6s ease, transform .6s ease;
}
#splashScreen.hide{opacity:0;transform:scale(1.04);pointer-events:none}
.splash-logo{
  animation:splashPop .7s cubic-bezier(.34,1.56,.64,1) forwards;
  opacity:0;
}
@keyframes splashPop{
  0%{opacity:0;transform:scale(.6) translateY(20px)}
  100%{opacity:1;transform:scale(1) translateY(0)}
}
.splash-bar-track{
  width:160px;height:3px;background:rgba(255,255,255,.08);
  border-radius:10px;margin-top:40px;overflow:hidden;
}
.splash-bar-fill{
  height:100%;width:0%;border-radius:10px;
  background:linear-gradient(90deg,#00FF87,#00D4FF);
  animation:splashLoad 2s ease forwards;
  animation-delay:.4s;
}
@keyframes splashLoad{
  0%{width:0%}
  60%{width:75%}
  85%{width:90%}
  100%{width:100%}
}
.splash-tagline{
  margin-top:18px;font-family:'Barlow Condensed',sans-serif;
  font-size:15px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;
  background:linear-gradient(90deg,#00FF87,#00D4FF);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  opacity:0;animation:fadeIn .5s ease .6s forwards;
}
@keyframes fadeIn{to{opacity:1}}
.splash-version{
  position:absolute;bottom:calc(24px + env(safe-area-inset-bottom,0px));
  font-size:11px;color:rgba(255,255,255,.2);letter-spacing:.5px;
  opacity:0;animation:fadeIn .5s ease 1s forwards;
}

/* ── LOGIN PAGE ─────────────────────────────────────────── */
.login-page{
  min-height:100dvh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:30px 24px;
  background:radial-gradient(ellipse at 50% 0%,rgba(0,255,135,.08) 0%,transparent 60%);
}
.login-logo{text-align:center;margin-bottom:40px}
.login-badge{
  width:80px;height:80px;border-radius:22px;background:var(--grd);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-title);font-weight:900;font-size:44px;color:#0A0F1A;
  margin:0 auto 16px;
}
.login-name{font-family:var(--font-title);font-size:38px;font-weight:900;letter-spacing:1px}
.login-name em{font-style:normal;background:var(--grd);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.login-tagline{color:var(--muted);font-size:14px;margin-top:4px}
.login-card{
  width:100%;max-width:360px;background:var(--bg2);
  border-radius:20px;border:1px solid var(--border2);padding:24px;
}
.login-tabs{display:flex;background:var(--bg4);border-radius:10px;padding:3px;margin-bottom:20px;gap:3px}
.login-tab{
  flex:1;padding:9px;text-align:center;border-radius:8px;cursor:pointer;
  font-weight:700;font-size:13px;transition:.2s;color:var(--muted);
}
.login-tab.active{background:var(--bg2);color:var(--text)}

/* ── NOTIFICATIONS ──────────────────────────────────────── */
.notif-item{
  display:flex;gap:11px;padding:13px;border-radius:var(--r-sm);
  background:var(--bg4);border:1px solid var(--border);margin-bottom:8px;
}
.notif-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;margin-top:4px}
.notif-text{font-size:13px;font-weight:600;margin-bottom:3px}
.notif-time{font-size:11px;color:var(--muted)}

/* ── TOAST ──────────────────────────────────────────────── */
.toast{
  position:fixed;top:18px;left:50%;transform:translateX(-50%) translateY(-80px);
  background:var(--bg3);border:1px solid var(--border2);border-radius:50px;
  padding:12px 20px;font-size:13px;font-weight:700;z-index:1000;
  transition:transform .4s cubic-bezier(.34,1.56,.64,1);
  white-space:nowrap;box-shadow:0 8px 36px rgba(0,0,0,.6);display:flex;align-items:center;gap:8px;
}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.ok{border-color:rgba(0,255,135,.3);color:var(--green)}
.toast.err{border-color:rgba(255,61,90,.3);color:var(--red)}
.toast.inf{border-color:rgba(0,212,255,.3);color:var(--cyan)}

/* ── EMPTY ──────────────────────────────────────────────── */
.empty{text-align:center;padding:50px 20px}
.empty-ico{font-size:56px;margin-bottom:14px}
.empty-title{font-family:var(--font-title);font-size:24px;font-weight:800;margin-bottom:8px}
.empty-desc{color:var(--muted);font-size:14px;line-height:1.6}

/* ── PROFILE CARD ───────────────────────────────────────── */
.profile-row{
  display:flex;align-items:center;gap:13px;padding:14px 16px;
  background:var(--bg4);border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:8px;cursor:pointer;
}
.profile-row:active{transform:scale(.98)}
.avatar{
  width:44px;height:44px;border-radius:14px;flex-shrink:0;
  background:var(--grd);display:flex;align-items:center;justify-content:center;
  font-family:var(--font-title);font-weight:900;font-size:22px;color:#0A0F1A;
}
.avatar.player{background:linear-gradient(135deg,var(--purple),var(--blue))}
.pname{font-weight:700;font-size:14px}
.prole{font-size:11px;color:var(--muted);margin-top:2px}

/* ── PAYMENT ─────────────────────────────────────────────── */
.receipt-preview{
  background:var(--bg4);border-radius:var(--r-sm);padding:12px;
  border:1px solid var(--border2);margin-top:10px;text-align:center;
}
.receipt-img{max-height:200px;border-radius:8px;object-fit:contain}

/* ── GROUP SELECTOR ─────────────────────────────────────── */
.user-pick{
  display:flex;align-items:center;gap:10px;padding:10px 13px;
  background:var(--bg4);border-radius:var(--r-sm);border:1px solid var(--border);
  margin-bottom:7px;cursor:pointer;transition:.2s;
}
.user-pick.sel{border-color:var(--green);background:rgba(0,255,135,.06)}
.user-pick:active{transform:scale(.97)}
.user-pick-check{
  width:20px;height:20px;border-radius:50%;border:2px solid var(--border2);
  display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;
}
.user-pick.sel .user-pick-check{background:var(--green);border-color:var(--green);color:#0A0F1A}

/* ── CONFIG SECTION ─────────────────────────────────────── */
.cfg-item{
  display:flex;align-items:center;gap:13px;padding:14px 16px;
  background:var(--bg4);border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:8px;
  cursor:pointer;transition:.2s;
}
.cfg-item:active{transform:scale(.98)}
.cfg-ico{font-size:22px;width:32px;text-align:center;flex-shrink:0}
.cfg-lbl{font-weight:600;font-size:14px}
.cfg-desc{font-size:11px;color:var(--muted);margin-top:2px}
.cfg-arrow{margin-left:auto;color:var(--muted);font-size:18px}

/* ── BASEROW SETUP ──────────────────────────────────────── */
.baserow-setup{padding:20px;background:var(--card);border-radius:var(--r);border:1px solid var(--border);margin-bottom:14px}
.setup-title{font-family:var(--font-title);font-size:20px;font-weight:800;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.setup-step{
  display:flex;gap:12px;margin-bottom:12px;align-items:flex-start;
  padding:10px;background:var(--bg4);border-radius:var(--r-sm);
}
.step-num{
  width:24px;height:24px;border-radius:50%;background:var(--grd);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:900;color:#0A0F1A;flex-shrink:0;
}
.step-text{font-size:13px;line-height:1.5}
.step-text code{
  background:var(--bg5);padding:1px 5px;border-radius:4px;
  font-family:monospace;font-size:12px;color:var(--cyan);
}

/* Animations */
@keyframes spin{to{transform:rotate(360deg)}}
.spin{animation:spin .8s linear infinite;display:inline-block}

/* Connection status */
.conn-status{display:flex;align-items:center;gap:7px;font-size:12px;padding:8px 14px;border-radius:50px;margin-bottom:12px}
.conn-status.ok{background:rgba(0,255,135,.08);color:var(--green);border:1px solid rgba(0,255,135,.2)}
.conn-status.err{background:rgba(255,61,90,.08);color:var(--red);border:1px solid rgba(255,61,90,.2)}
.conn-dot{width:7px;height:7px;border-radius:50%;background:currentColor}

/* Level badge */
.level-badge{
  padding:2px 8px;border-radius:50px;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;margin-left:6px;
}
.level-badge.admin{background:rgba(255,176,32,.15);color:var(--amber)}
.level-badge.player{background:rgba(77,184,255,.15);color:var(--blue)}

/* ── BOTÃO VOLTAR ────────────────────────────────────────── */
.back-btn{
  display:flex;align-items:center;gap:8px;padding:10px 0 4px;
  background:none;border:none;color:var(--muted);cursor:pointer;
  font-family:var(--font-body);font-size:14px;font-weight:600;
  transition:.2s;
}
.back-btn:active{opacity:.6}
.back-arrow{font-size:20px;line-height:1}

/* ── AVATAR PICKER ───────────────────────────────────────── */
.avatar-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px;
}
.avatar-opt{
  width:100%;aspect-ratio:1;border-radius:50%;border:2px solid var(--border2);
  display:flex;align-items:center;justify-content:center;font-size:28px;
  cursor:pointer;transition:.2s;background:var(--bg4);
}
.avatar-opt.sel{border-color:var(--green);background:rgba(0,255,135,.1);transform:scale(1.08)}
.avatar-opt:active{transform:scale(.92)}
.avatar-large{
  width:90px;height:90px;border-radius:50%;border:3px solid var(--green);
  display:flex;align-items:center;justify-content:center;
  font-size:52px;margin:0 auto 12px;background:var(--bg4);
  cursor:pointer;transition:.2s;position:relative;
}
.avatar-large::after{
  content:'✏️';position:absolute;bottom:-2px;right:-2px;
  font-size:18px;background:var(--bg2);border-radius:50%;width:28px;height:28px;
  display:flex;align-items:center;justify-content:center;
}

/* ── CURRENCY INPUT ──────────────────────────────────────── */
.currency-wrap{position:relative}
.currency-prefix{
  position:absolute;left:14px;top:50%;transform:translateY(-50%);
  color:var(--muted);font-size:14px;font-weight:600;pointer-events:none;
}
.currency-wrap .fi{padding-left:40px}

/* Upload area */
.upload-area{
  border:2px dashed var(--border2);border-radius:var(--r-sm);padding:20px;
  text-align:center;cursor:pointer;transition:.2s;color:var(--muted);font-size:13px;
}
.upload-area:hover{border-color:var(--cyan);color:var(--cyan)}
.upload-area input{display:none}

/* ── PASSWORD FIELD WITH EYE ─────────────────────────────── */
.pw-wrap{position:relative}
.pw-wrap .fi{padding-right:46px;width:100%}
.pw-eye{
  position:absolute;right:14px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;color:var(--muted);
  font-size:18px;padding:4px;transition:color .2s;line-height:1;
}
.pw-eye:hover{color:var(--text)}

/* ── REMEMBER ME ─────────────────────────────────────────── */
.remember-row{
  display:flex;align-items:center;justify-content:space-between;
  margin:12px 0 16px;
}
.remember-check{display:flex;align-items:center;gap:8px;cursor:pointer}
.remember-check input[type=checkbox]{
  width:17px;height:17px;border-radius:4px;accent-color:var(--green);cursor:pointer;
}
.remember-label{font-size:13px;color:var(--muted);font-weight:500}
.forgot-link{
  font-size:13px;color:var(--cyan);font-weight:600;cursor:pointer;
  background:none;border:none;padding:0;transition:opacity .2s;
}
.forgot-link:hover{opacity:.7}

/* ── FORGOT PASSWORD MODAL ───────────────────────────────── */
.forgot-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:600;
  display:none;align-items:center;justify-content:center;padding:20px;
  backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
}
.forgot-modal.open{display:flex}
.forgot-box{
  background:var(--bg2);border:1px solid var(--border2);border-radius:20px;
  padding:28px 24px;width:100%;max-width:340px;
}
.forgot-title{font-family:var(--font-title);font-size:24px;font-weight:900;margin-bottom:6px}
.forgot-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px}
.forgot-steps{background:var(--bg4);border-radius:var(--r-sm);padding:14px;margin-bottom:16px}
.forgot-step{display:flex;gap:10px;margin-bottom:10px;font-size:13px;line-height:1.5;color:var(--muted)}
.forgot-step:last-child{margin-bottom:0}
.forgot-step-num{
  width:22px;height:22px;border-radius:50%;background:var(--grd);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:900;color:#0A0F1A;flex-shrink:0;
}
.forgot-close{
  width:100%;padding:12px;border-radius:var(--r-sm);
  background:var(--bg4);border:1px solid var(--border2);
  color:var(--text);font-size:14px;font-weight:700;cursor:pointer;
  font-family:var(--font-body);transition:.2s;
}
.forgot-close:hover{background:var(--bg5)}
/* ── TIMER FAB ───────────────────────────────────────────── */
#timerFab{
  position:fixed;bottom:calc(146px + var(--safe-b));right:16px;
  width:58px;height:58px;border-radius:50%;
  background:linear-gradient(135deg,var(--amber),#FF6B00);
  border:none;color:#fff;font-size:13px;font-weight:900;
  cursor:pointer;display:none;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(255,176,32,.5);z-index:100;
  transition:.2s;flex-direction:column;gap:1px;line-height:1;
}
#timerFab.running{background:linear-gradient(135deg,#FF3D5A,#FF6B00);
  animation:timerPulse 1s ease-in-out infinite;}
@keyframes timerPulse{0%,100%{box-shadow:0 4px 20px rgba(255,61,90,.5)}
  50%{box-shadow:0 4px 30px rgba(255,61,90,.9)}}
#timerFab:active{transform:scale(.88)}
.timer-display{font-size:26px;font-weight:900;font-family:monospace;letter-spacing:-1px}
.timer-minutes{font-size:28px;font-weight:900;font-family:monospace}

/* ── TIMER MODAL ─────────────────────────────────────────── */
.timer-big{
  font-size:72px;font-weight:900;font-family:monospace;
  background:var(--grd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;
  text-align:center;margin:20px 0 8px;line-height:1;
}
.timer-big.ending{background:linear-gradient(135deg,var(--red),var(--amber));-webkit-background-clip:text;}
.timer-presets{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:16px}
.timer-preset{
  padding:8px 16px;border-radius:50px;background:var(--bg4);
  border:1px solid var(--border2);cursor:pointer;font-size:13px;font-weight:700;
  transition:.2s;
}
.timer-preset.sel{background:var(--grd);color:#0A0F1A;border-color:transparent}
.timer-preset:active{transform:scale(.92)}
.timer-ctrl{display:flex;gap:10px;justify-content:center;margin-top:14px}

/* ── SCOREBOARD ──────────────────────────────────────────── */
.score-wrap{display:flex;align-items:center;gap:10px;margin:16px 0}
.score-team{flex:1;text-align:center}
.score-name{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:6px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.score-num{font-family:var(--font-title);font-size:52px;font-weight:900;
  background:var(--grd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;
  cursor:pointer;user-select:none;line-height:1;padding:10px 0;}
.score-sep{font-family:var(--font-title);font-size:36px;font-weight:900;color:var(--muted2);flex-shrink:0}
.score-btns{display:flex;gap:6px;justify-content:center;margin-top:4px}
.score-btn{width:36px;height:36px;border-radius:50%;border:none;cursor:pointer;
  font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:.2s}
.score-btn.plus{background:rgba(0,255,135,.15);color:var(--green)}
.score-btn.minus{background:rgba(255,61,90,.1);color:var(--red)}
.score-btn:active{transform:scale(.85)}

/* ── TEAMS MIXER ─────────────────────────────────────────── */
.team-card{
  background:var(--bg4);border-radius:var(--r-sm);
  border:1px solid var(--border);padding:12px;margin-bottom:10px;
}
.team-header{
  display:flex;align-items:center;gap:8px;margin-bottom:8px;
  font-family:var(--font-title);font-size:18px;font-weight:800;
}
.team-badge{
  width:32px;height:32px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:14px;color:#0A0F1A;flex-shrink:0;
}
.team-player{font-size:13px;padding:5px 0;border-bottom:1px solid var(--border);color:var(--muted)}
.team-player:last-child{border-bottom:none}
.matchup-row{
  display:flex;align-items:center;gap:8px;padding:10px;
  background:var(--bg4);border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:8px;
  font-size:13px;font-weight:700;
}
.matchup-vs{font-size:11px;color:var(--muted);flex-shrink:0}

/* ── HISTORY ─────────────────────────────────────────────── */
.hist-card{
  background:var(--card);border-radius:var(--r-sm);border:1px solid var(--border);
  padding:13px 14px;margin-bottom:10px;
}
.hist-title{font-weight:700;font-size:14px;margin-bottom:4px}
.hist-meta{font-size:11px;color:var(--muted);display:flex;flex-wrap:wrap;gap:6px;margin-bottom:6px}
.hist-chip{background:var(--bg4);padding:2px 8px;border-radius:50px;font-size:11px}
/* ── TUTORIAL ─────────────────────────────────────────────── */
.tut-slide{animation:fadeUp .3s ease}
.tut-item{
  display:flex;align-items:flex-start;gap:12px;
  background:var(--bg4);border-radius:var(--r-sm);
  border:1px solid var(--border);padding:12px 13px;
}
.tut-ico{
  width:36px;height:36px;border-radius:10px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;background:var(--bg5);font-weight:900;
}
.tut-ico.tut-green{background:rgba(0,255,135,.15);color:var(--green);font-size:14px}
.tut-ico.tut-amber{background:rgba(255,176,32,.15);color:var(--amber);font-size:14px}
.tut-ico.tut-muted{background:var(--bg5);color:var(--muted);font-size:14px}
.tut-lbl{font-size:13px;font-weight:700;margin-bottom:3px}
.tut-desc{font-size:12px;color:var(--muted);line-height:1.5}
.tut-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--bg5);border:1px solid var(--border2);
  cursor:pointer;transition:.2s;
}
.tut-dot.active{background:var(--green);border-color:var(--green);width:20px;border-radius:50px}
/* ── STAR RATING ─────────────────────────────────────── */
.star-btn{
  font-size:34px;cursor:pointer;transition:.15s;filter:grayscale(1);opacity:.4;
  user-select:none;-webkit-user-select:none;
}
.star-btn.active,.star-btn:hover{filter:none;opacity:1;transform:scale(1.15)}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  SPLASH SCREEN                                         -->
<!-- ═══════════════════════════════════════════════════════ -->
<div id="splashScreen">
  <div class="splash-logo">
    <img src="https://i.ibb.co/fYXRYLq4/logoconfai.png"
         alt="ConfirmaAí"
         style="width:200px;height:200px;object-fit:contain;filter:drop-shadow(0 0 40px rgba(0,255,135,.35))" />
  </div>
  <div class="splash-tagline">Gestão inteligente de partidas</div>
  <div class="splash-bar-track">
    <div class="splash-bar-fill"></div>
  </div>
  <div class="splash-version">ConfirmaAí v2.0</div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!--  LOGIN PAGE                                            -->
<!-- ═══════════════════════════════════════════════════════ -->
<div id="loginPage" class="login-page">
  <div class="login-logo">
    <img src="https://i.ibb.co/fYXRYLq4/logoconfai.png" alt="ConfirmaAí" style="width:160px;height:160px;object-fit:contain;margin-bottom:4px;filter:drop-shadow(0 4px 24px rgba(0,255,135,.25))" />
    <div class="login-tagline">⚡ Gestão inteligente de partidas</div>
  </div>
  <div class="login-card">
    <div class="login-tabs">
      <div class="login-tab active" id="tabLogin" onclick="switchAuthTab('login')">Entrar</div>
      <div class="login-tab" id="tabReg" onclick="switchAuthTab('register')">Cadastrar</div>
    </div>
    <!-- Login form -->
    <div id="formLogin">
      <div class="fg">
        <label class="fl">Login</label>
        <input class="fi" id="lLogin" placeholder="Seu login" autocomplete="username" />
      </div>
      <div class="fg">
        <label class="fl">Senha</label>
        <div class="pw-wrap">
          <input class="fi" id="lSenha" type="password" placeholder="••••••" autocomplete="current-password" />
          <button class="pw-eye" type="button" onclick="toggleEye('lSenha','eyeLogin')" id="eyeLogin" title="Mostrar/ocultar senha">👁️</button>
        </div>
      </div>
      <div class="remember-row">
        <label class="remember-check">
          <input type="checkbox" id="rememberMe" onchange="handleRemember()" />
          <span class="remember-label">Lembrar acesso</span>
        </label>
        <button class="forgot-link" onclick="openForgot()">Esqueceu a senha?</button>
      </div>
      <button class="btn btn-primary btn-full" onclick="doLogin()">Entrar</button>
      <div id="loginErr" style="color:var(--red);font-size:12px;margin-top:10px;text-align:center"></div>
    </div>
    <!-- Register form -->
    <div id="formReg" style="display:none">
      <div class="fg"><label class="fl">Nome completo</label><input class="fi" id="rNome" placeholder="Seu nome" autocomplete="name" /></div>
      <div class="fg"><label class="fl">Login</label><input class="fi" id="rLogin" placeholder="login único" autocomplete="username" /></div>
      <div class="fg">
        <label class="fl">Senha</label>
        <div class="pw-wrap">
          <input class="fi" id="rSenha" type="password" placeholder="••••••" autocomplete="new-password" />
          <button class="pw-eye" type="button" onclick="toggleEye('rSenha','eyeReg')" id="eyeReg" title="Mostrar/ocultar senha">👁️</button>
        </div>
      </div>
      <div class="fg">
        <label class="fl">Modalidades de interesse</label>
        <div class="sport-grid" id="regSports">
<div class="sport-opt sel" data-sport="futebol" onclick="toggleSport(this)"><span class="se">⚽</span>Futebol</div>
          <div class="sport-opt" data-sport="futsal" onclick="toggleSport(this)"><span class="se">🥅</span>Futsal</div>
          <div class="sport-opt" data-sport="volei" onclick="toggleSport(this)"><span class="se">🏐</span>Vôlei</div>
          <div class="sport-opt" data-sport="basquete" onclick="toggleSport(this)"><span class="se">🏀</span>Basquete</div>
          <div class="sport-opt" data-sport="tenis" onclick="toggleSport(this)"><span class="se">🎾</span>Tênis</div>
          <div class="sport-opt" data-sport="futebolAreia" onclick="toggleSport(this)"><span class="se">⛱️</span>Futebol de Areia</div>
